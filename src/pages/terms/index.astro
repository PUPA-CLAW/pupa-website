---
import Layout from '../../layouts/Layout.astro';
import { Content as Terms } from '../../data/terms.md';
---
<Layout lang="en" routeKey="terms" title="Terms of Use | PUPA Center" description="The rules for using the PUPA Center website — how you may use our content, our intellectual property, donations, external links, and the law that applies.">
  <section class="terms-sec"><div class="wrap narrow">
    <Terms />
  </div></section>
</Layout>
<style>
.narrow{max-width:760px}
.terms-sec{padding:56px 0 80px}
.terms-sec :global(h1){font-size:clamp(1.9rem,4vw,2.6rem);margin:8px 0 12px}
.terms-sec :global(h2){margin:8px 0 12px}
.terms-sec :global(h3){margin:28px 0 10px}
.terms-sec :global(h4){margin:20px 0 8px}
.terms-sec :global(p),.terms-sec :global(li){color:var(--ink-soft);font-size:15px;line-height:1.6}
.terms-sec :global(ul){padding-left:22px;margin:10px 0}
</style>
