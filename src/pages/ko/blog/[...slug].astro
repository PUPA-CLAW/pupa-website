---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => p.data.lang === 'ko');
  return posts.map((p) => ({ params: { slug: p.data.slug }, props: { post: p } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<ArticleLayout lang="ko" routeKey="blog" title={post.data.title} description={post.data.description ?? ''} date={post.data.date} image={post.data.image} backHref="/ko/blog/" backLabel="아티클 & 가이드 전체 보기">
  <Content />
</ArticleLayout>
