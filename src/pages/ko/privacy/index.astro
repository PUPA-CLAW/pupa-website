---
import Layout from '../../../layouts/Layout.astro';
import { Content as PrivacyKo } from '../../../data/privacy-ko.md';
---
<Layout lang="ko" routeKey="privacy" title="개인정보 처리방침 | PUPA Center" description="PUPA 센터가 웹사이트와 WhatsApp·Telegram 메시지 서비스를 통해 개인정보를 어떻게 수집·이용·보관·보호하는지 안내합니다.">
  <section class="privacy-sec"><div class="wrap narrow">
    <PrivacyKo />
  </div></section>
</Layout>
<style>
.narrow{max-width:760px}
.privacy-sec{padding:56px 0 80px}
.privacy-sec :global(h1){font-size:clamp(1.9rem,4vw,2.6rem);margin:8px 0 12px}
.privacy-sec :global(h2){margin:8px 0 12px}
.privacy-sec :global(h3){margin:28px 0 10px}
.privacy-sec :global(h4){margin:20px 0 8px}
.privacy-sec :global(p),.privacy-sec :global(li){color:var(--ink-soft);font-size:15px;line-height:1.6}
.privacy-sec :global(ul){padding-left:22px;margin:10px 0}
</style>
