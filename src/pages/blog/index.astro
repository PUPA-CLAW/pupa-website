---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
const posts = (await getCollection('blog')).sort((a, b) => +b.data.date - +a.data.date);
---
<Layout lang="en" routeKey="blog" title="Parent Resources | PUPA Center" description="Practical articles for families of neurodivergent young adults: independence, life skills, routines, executive function, and the transition to adulthood.">
  <section class="page-head"><div class="wrap">
    <h1>Parent resources</h1>
    <p class="lede">Practical articles for families of neurodivergent young adults — independence, routines, life skills, and the transition to adulthood.</p>
  </div></section>
  <section class="listing"><div class="wrap">
    <div class="post-grid">
      {posts.map((p) => (
        <a class="post-card" href={`/blog/${p.data.slug}/`}>
          {p.data.image && <img src={p.data.image} alt="" loading="lazy" />}
          <div class="post-info">
            <h2>{p.data.title}</h2>
            <p>{p.data.description}…</p>
          </div>
        </a>
      ))}
    </div>
  </div></section>
</Layout>
<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid var(--line)}
.page-head .lede{font-size:1.15rem;color:var(--ink-soft);margin-top:18px}
.listing{padding:56px 0}
.post-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
.post-card{display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--line);border-radius:var(--radius-lg);overflow:hidden;text-decoration:none;color:var(--ink)}
.post-card:hover h2{color:var(--teal-700)}
.post-card img{width:100%;aspect-ratio:16/9;object-fit:cover}
.post-info{padding:20px 22px}
.post-info h2{font-size:1.2rem;margin-bottom:8px}
.post-info p{font-size:.97rem;color:var(--ink-soft)}
@media (max-width:960px){.post-grid{grid-template-columns:1fr}}
</style>
