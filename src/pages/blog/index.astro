---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', (p) => p.data.lang === 'en' && +p.data.date <= Date.now())).sort((a, b) => +b.data.date - +a.data.date);

// Clean one-line summary: trim to ~110 chars ending at a word boundary
function summarize(text: string): string {
  if (!text) return '';
  const clean = text.trim();
  if (clean.length <= 115) return clean;
  const cut = clean.slice(0, 115);
  const lastSpace = cut.lastIndexOf(' ');
  return cut.slice(0, lastSpace > 0 ? lastSpace : 115).replace(/[,;:]$/, '') + '…';
}

const fmtDate = (d: Date) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---
<Layout lang="en" routeKey="blog" title="Parent Resources | PUPA Center" description="Practical articles for families of neurodivergent young adults: independence, life skills, routines, executive function, and the transition to adulthood.">
  <section class="page-head"><div class="wrap">
    <h1>Parent Resources</h1>
    <p class="lede">Practical articles for families of neurodivergent young adults — independence, routines, life skills, and the transition to adulthood.</p>
  </div></section>

  <section class="listing"><div class="wrap">
    <div class="post-grid">
      {posts.map((p) => (
        <a class="post-card" href={`/blog/${p.data.slug}/`}>
          {p.data.image && <img class="post-thumb" src={p.data.image} alt="" loading="lazy" width="360" height="225" />}
          <div class="post-info">
            <h2>{p.data.title}</h2>
            <p class="post-excerpt">{summarize(p.data.description)}</p>
            <span class="post-date">{fmtDate(p.data.date)}</span>
          </div>
        </a>
      ))}
    </div>
  </div></section>
</Layout>

<style>
.page-head{background:var(--cream);padding:56px 0 40px;border-bottom:1px solid #EFE4D2}
.page-head .lede{font-size:1.12rem;color:var(--ink-soft);margin-top:16px;max-width:64ch}

.listing{padding:44px 0 64px}
.post-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.post-card{display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--line);border-radius:16px;overflow:hidden;text-decoration:none;color:var(--ink);transition:transform .2s ease,box-shadow .2s ease}
.post-card:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(11,68,65,.1)}
.post-card:hover h2{color:var(--teal-700)}
.post-thumb{width:100%;aspect-ratio:16/10;object-fit:cover}
.post-info{padding:18px 20px 20px;display:flex;flex-direction:column;gap:8px;flex-grow:1}
.post-info h2{font-size:1.12rem;line-height:1.3;transition:color .2s ease}
.post-excerpt{font-size:.9rem;color:var(--ink-soft);line-height:1.5;flex-grow:1}
.post-date{font-size:.82rem;color:var(--ink-soft);margin-top:4px}

@media (max-width:900px){.post-grid{grid-template-columns:1fr 1fr}}
@media (max-width:600px){.post-grid{grid-template-columns:1fr}}
</style>
