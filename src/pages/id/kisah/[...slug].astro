---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
export async function getStaticPaths() {
  const stories = await getCollection('stories', (s) => s.data.lang === 'id');
  return stories.map((s) => ({ params: { slug: s.data.slug }, props: { story: s } }));
}
const { story } = Astro.props;
const { Content } = await render(story);
---
<ArticleLayout lang="id" routeKey="stories" title={story.data.title} description={story.data.description ?? ''} date={story.data.date} image={story.data.image} backHref="/id/kisah/" backLabel="Semua kisah pertumbuhan">
  <Content />
</ArticleLayout>
