---
import Layout from '../../../layouts/Layout.astro';
import { Content as Privasi } from '../../../data/privasi.md';
---
<Layout lang="id" routeKey="privacy" title="Kebijakan Privasi | PUPA Center" description="Bagaimana PUPA Center mengumpulkan, menggunakan, menyimpan, dan melindungi data pribadi di situs web kami serta melalui layanan pesan WhatsApp dan Telegram.">
  <section class="privacy-sec"><div class="wrap narrow">
    <Privasi />
  </div></section>
</Layout>
<style>
.narrow{max-width:760px}
.privacy-sec{padding:56px 0 80px}
.privacy-sec :global(h1){font-size:clamp(1.9rem,4vw,2.6rem);margin:8px 0 12px}
.privacy-sec :global(h2){margin:8px 0 12px}
.privacy-sec :global(h3){margin:28px 0 10px}
.privacy-sec :global(h4){margin:20px 0 8px}
.privacy-sec :global(p),.privacy-sec :global(li){color:var(--ink-soft)}
.privacy-sec :global(ul){padding-left:22px;margin:10px 0}
</style>
