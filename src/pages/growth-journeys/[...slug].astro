---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
export async function getStaticPaths() {
  const stories = await getCollection('stories', (s) => s.data.lang === 'en');
  return stories.map((s) => ({ params: { slug: s.data.slug }, props: { story: s } }));
}
const { story } = Astro.props;
const { Content } = await render(story);
---
<ArticleLayout lang="en" routeKey="stories" title={story.data.title} description={story.data.description ?? ''} image={story.data.image} backHref="/growth-journeys/" backLabel="All growth journeys">
  <Content />
</ArticleLayout>
