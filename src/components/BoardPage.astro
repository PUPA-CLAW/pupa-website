---
import Layout from '../layouts/Layout.astro';
import { type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

// Board members. Order: Patron, Founder, then advisors.
const members = [
  {
    slug: 'fonda', name: 'Fonda',
    role: { en: 'Patron', id: 'Pembina' },
    bio: {
      en: 'Ibu Fonda has stood behind PUPA Center since day one. Her commitment to this work runs deep. Growing up with a neurodivergent sister shaped the way she sees the people PUPA serves and strengthened her belief that everyone deserves opportunity, dignity, and a future worth striving for. As Patron, she is the quiet, steady presence who keeps the foundation close to its purpose through both successes and setbacks.',
      id: 'Ibu Fonda telah mendampingi PUPA Center sejak hari pertama. Komitmennya terhadap misi ini begitu dalam. Tumbuh bersama saudara perempuannya yang neurodivergen membentuk cara pandangnya terhadap mereka yang dilayani PUPA, sekaligus menguatkan keyakinannya bahwa setiap orang berhak atas kesempatan, martabat, dan masa depan yang layak diperjuangkan. Sebagai Pembina, ia hadir sebagai sosok yang tenang dan teguh, yang menjaga yayasan ini tetap setia pada tujuannya di masa keberhasilan maupun di saat-saat sulit.',
    },
  },
  {
    slug: 'robert', name: 'Robert Erizo Kusnadi',
    role: { en: 'Vice Patron', id: 'Wakil Pembina' },
    linkedin: 'https://www.linkedin.com/in/robert-erizo-kusnadi-4a199860/',
    bio: {
      en: 'Currently taking a deeper dive into the disability world, Robert is pursuing a PhD in Special Education & Disability Policy at Virginia Commonwealth University, where he is also a college instructor for disability undergraduate courses. He holds a bachelor\u2019s degree in Theology and Business Administration from Oral Roberts University and a master\u2019s in Industrial & Organizational Psychology from the University of Oklahoma. He looks forward to leveraging his extensive entrepreneurial experience and academic pursuits for the flourishing of people with disabilities.',
      id: 'Saat ini sedang mendalami dunia disabilitas, Robert menempuh studi S3 dalam bidang Pendidikan Luar Biasa (PLB) dan Kebijakan Disabilitas di Virginia Commonwealth University, tempat ia juga menjadi pengajar untuk mata kuliah disabilitas jenjang sarjana. Ia meraih gelar Sarjana (S1) dalam bidang Teologi dan Administrasi Bisnis di Oral Roberts University, serta Magister (S2) dalam bidang Psikologi Industri dan Organisasi di University of Oklahoma. Ia berharap dapat memanfaatkan pengalaman kewirausahaan dan studi akademiknya bagi kemajuan penyandang disabilitas.',
    },
  },
  {
    slug: 'atikah', name: 'Atikah Bagawan, Ph.D.',
    role: { en: 'Supervisor', id: 'Pengawas' },
    bio: {
      en: 'Atikah wears many hats — as a sister to an individual with autism, an educator, and a researcher — and each role has shaped her passion for creating more inclusive opportunities for individuals with diverse needs and those who support them. She earned her bachelor\u2019s and master\u2019s degrees in Special Education from New Mexico State University, along with a graduate certificate in Autism Spectrum Disorder, and completed her PhD in Human Development and Family Studies at Michigan State University. Her experiences have reinforced her belief that meaningful change happens when research, education, and lived experience come together to improve the lives of individuals with disabilities.',
      id: 'Atikah memiliki banyak peran — sebagai saudara kandung dari individu dengan autisme, pendidik, dan peneliti — dan setiap peran tersebut membentuk semangatnya untuk menciptakan kesempatan yang lebih inklusif bagi individu dengan kebutuhan yang beragam serta orang-orang yang mendampingi mereka. Ia menyelesaikan pendidikan sarjana dan magister di bidang Pendidikan Luar Biasa di New Mexico State University, sekaligus memperoleh sertifikat pascasarjana dalam Autism Spectrum Disorder, dan melanjutkan studi doktoral di bidang Human Development and Family Studies di Michigan State University. Perjalanannya semakin menguatkan keyakinan bahwa perubahan yang bermakna terjadi ketika penelitian, pendidikan, dan pengalaman hidup saling melengkapi untuk meningkatkan kualitas hidup penyandang disabilitas.',
    },
  },
  {
    slug: 'joni', name: 'Joni',
    role: { en: 'Chair', id: 'Ketua Umum' },
    bio: {
      en: 'Joni founded PUPA Center 11 years ago, when it began as a small monthly gathering where parents could support one another. He saw what often happened after neurodivergent young people finished school: support systems disappeared, leaving families wondering what came next. Refusing to accept that reality, he built PUPA into what it is today — a place where neurodivergent young adults develop practical skills, greater independence, and meaningful opportunities for employment.',
      id: 'Joni mendirikan PUPA Center 11 tahun lalu, saat tempat ini bermula sebagai pertemuan bulanan kecil bagi para orang tua untuk saling menguatkan. Ia menyaksikan apa yang kerap terjadi setelah anak muda neurodivergen selesai sekolah: sistem dukungan menghilang, dan keluarga kebingungan harus melangkah ke mana. Menolak menerima kenyataan itu, ia membangun PUPA menjadi seperti sekarang — tempat bagi dewasa muda neurodivergen untuk mengembangkan keterampilan praktis, kemandirian yang lebih besar, dan peluang kerja yang bermakna.',
    },
  },
  {
    slug: 'uli', name: 'Uli Talina',
    role: { en: 'Treasurer', id: 'Bendahara' },
    bio: {
      en: 'Uli Talina is a Finance and Tax Consultant based in Bandung, Indonesia. She holds a bachelor\u2019s degree in Accountancy from Saint Louis University in the Philippines and currently oversees the foundation\u2019s accounting and tax matters. She began her career as an auditor at Ernst & Young (EY) before working as a consultant on a wide range of projects across various industries.',
      id: 'Uli Talina adalah Konsultan Keuangan dan Pajak yang berdomisili di Bandung, Indonesia. Ia meraih gelar Sarjana Akuntansi dari Saint Louis University, Filipina, dan saat ini menangani urusan akuntansi dan perpajakan yayasan. Ia memulai kariernya sebagai auditor di Ernst & Young (EY) sebelum bekerja sebagai konsultan untuk beragam proyek di berbagai industri.',
    },
  },
  {
    slug: 'lulu', name: 'Lulu Gunawan',
    role: { en: 'Secretary', id: 'Sekretaris' },
    bio: {
      en: 'With nearly 20 years of experience in education, Lulu is honored to be part of PUPA and support the well-being of the community. As a proud mother of two, she believes in building strong partnerships with families to help every student reach their full potential. She holds a bachelor\u2019s degree in Industrial Engineering and Management from Oklahoma State University and a master\u2019s degree in Curriculum, Instruction, and Assessment from Walden University.',
      id: 'Dengan pengalaman hampir 20 tahun di dunia pendidikan, Lulu merasa terhormat dapat menjadi bagian dari PUPA dan mendukung kesejahteraan komunitas. Sebagai ibu dari dua anak, ia percaya pada pentingnya membangun kemitraan yang kuat dengan keluarga untuk membantu setiap siswa meraih potensi penuhnya. Ia memegang gelar Sarjana Teknik Industri dan Manajemen dari Oklahoma State University serta Magister dalam Kurikulum, Instruksi, dan Asesmen dari Walden University.',
    },
  },

];

const content = {
  en: {
    metaTitle: 'Board & Advisors — PUPA Center',
    metaDescription: 'Meet the patron, founder, and advisors who guide PUPA Center — educators, researchers, and professionals committed to neurodivergent young adults in Indonesia.',
    h1: 'Board & Advisors',
    intro: 'PUPA Center is guided by its foundation board — a patron, vice patron, supervisor, chair, treasurer, and secretary who bring together lived experience, education, research, and professional expertise, all committed to a future where neurodivergent young adults live a life that matters.',
  },
  id: {
    metaTitle: 'Pembina & Penasihat — PUPA Center',
    metaDescription: 'Kenali pembina, pendiri, dan para penasihat yang memandu PUPA Center — pendidik, peneliti, dan profesional yang berkomitmen bagi anak muda neurodivergen di Indonesia.',
    h1: 'Pembina & Penasihat',
    intro: 'PUPA Center dipandu oleh pengurus yayasan — pembina, wakil pembina, pengawas, ketua umum, bendahara, dan sekretaris yang memadukan pengalaman hidup, pendidikan, penelitian, dan keahlian profesional, semuanya berkomitmen pada masa depan di mana anak muda neurodivergen menjalani hidup yang bermakna.',
  },
};
const c = content[lang];
---
<Layout lang={lang} routeKey="board" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
      <p class="lede">{c.intro}</p>
    </div>
  </section>

  <section class="board">
    <div class="wrap">
      {members.map((m, i) => (
        <article class={`board-row ${i % 2 ? 'reverse' : ''}`}>
          <div class="board-photo">
            <img class={i % 2 ? 'blob-alt' : 'blob'} src={`/images/board/${m.slug}.jpg`} alt={`${m.name}, ${m.role[lang]} at PUPA Center`} loading="lazy" width="360" height="450" />
          </div>
          <div class="board-info">
            <p class="board-role">{m.role[lang]}</p>
            <h2>{m.name}</h2>
            <p class="board-bio">{m.bio[lang]}</p>
            {m.linkedin && <a class="board-link" href={m.linkedin} rel="noopener">LinkedIn →</a>}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid #EFE4D2}
.page-head .lede{font-size:1.15rem;color:var(--ink-soft);margin-top:18px;max-width:60ch}
.board{padding:64px 0}
.board-row{display:grid;grid-template-columns:.72fr 1.28fr;gap:44px;align-items:center;padding:36px 0;border-bottom:1px solid var(--line)}
.board-row:last-child{border-bottom:none}
.board-row.reverse{grid-template-columns:1.28fr .72fr}
.board-row.reverse .board-photo{order:2}
.board-photo img{width:100%;max-width:340px;aspect-ratio:4/5;object-fit:cover;box-shadow:0 14px 34px rgba(11,68,65,.14)}
.board-row:not(.reverse) .board-photo{justify-self:start}
.board-row.reverse .board-photo{justify-self:end}
.board-role{font-size:.82rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--orange-500)}
.board-info h2{margin:6px 0 14px;font-size:1.7rem}
.board-bio{color:var(--ink-soft)}
.board-link{display:inline-flex;align-items:center;min-height:44px;margin-top:14px;font-weight:600;text-decoration:none}
.board-link:hover{text-decoration:underline}
@media (max-width:820px){
  .board-row,.board-row.reverse{grid-template-columns:1fr;gap:24px;text-align:left}
  .board-row.reverse .board-photo{order:0;justify-self:start}
  .board-photo img{max-width:260px}
}
</style>
