---
import Layout from '../layouts/Layout.astro';
import { type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const waText = {
  en: encodeURIComponent('Hello PUPA Center team, I would like to know more about your programs. Thank you.'),
  id: encodeURIComponent('Halo tim PUPA Center, saya ingin mengetahui lebih lanjut mengenai program yang tersedia. Terima kasih.'),
};
const content = {
  en: {
    metaTitle: 'Contact PUPA Center — Visit Us in Alam Sutera, Tangerang',
    metaDescription: 'Contact PUPA Center for enrollment and inquiries. WhatsApp, email, or visit us at Ruko Prominence, Alam Sutera, Tangerang. Open Monday–Friday, 9:00 AM–3:00 PM WIB.',
    h1: 'Contact us',
    intro: 'The fastest way to reach us is WhatsApp. We will reply within one working day.',
    waBtn: 'Message us on WhatsApp',
    phoneTitle: 'Phone & WhatsApp',
    emailLabel: 'Email',
    visitTitle: 'Visit us',
    address: ['Ruko Prominence Blok 38E No. 42-43', 'Jl. Sutera Barat Boulevard', 'Alam Sutera, Tangerang 15143', 'Indonesia'],
    mapsBtn: 'Open in Google Maps',
    hoursTitle: 'Office hours',
    hours: 'Monday to Friday, 8:30 AM – 4:30 PM (WIB)',
    followTitle: 'Follow us',
  },
  id: {
    metaTitle: 'Kontak PUPA Center — Kunjungi Kami di Alam Sutera, Tangerang',
    metaDescription: 'Hubungi PUPA Center untuk pendaftaran dan pertanyaan. WhatsApp, email, atau kunjungi kami di Ruko Prominence, Alam Sutera, Tangerang. Buka Senin–Jumat, 09.00–15.00 WIB.',
    h1: 'Hubungi kami',
    intro: 'Cara tercepat menghubungi kami adalah melalui WhatsApp. Kami akan membalas dalam satu hari kerja.',
    waBtn: 'Kirim pesan via WhatsApp',
    phoneTitle: 'Telepon & WhatsApp',
    emailLabel: 'Email',
    visitTitle: 'Kunjungi kami',
    address: ['Ruko Prominence Blok 38E No. 42-43', 'Jl. Sutera Barat Boulevard', 'Alam Sutera, Tangerang 15143', 'Indonesia'],
    mapsBtn: 'Buka di Google Maps',
    hoursTitle: 'Jam operasional',
    hours: 'Senin sampai Jumat, pukul 08.30 – 16.30 WIB',
    followTitle: 'Ikuti kami',
  },
};
const c = content[lang];
const wa = `https://wa.me/62818533698?text=${waText[lang]}`;
---
<Layout lang={lang} routeKey="contact" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
      <p class="lede">{c.intro}</p>
      <a class="btn btn-primary" href={wa} rel="noopener">{c.waBtn}</a>
    </div>
  </section>

  <section class="map-sec">
    <div class="wrap">
      <iframe
        title="PUPA Center location map"
        src="https://maps.google.com/maps?q=Ruko%20Prominence%20Blok%2038E%20Alam%20Sutera%20Tangerang&z=15&output=embed"
        width="100%" height="380" style="border:0;border-radius:22px" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </section>

  <section class="contact-grid-sec">
    <div class="wrap">
      <div class="card-grid contact-grid">
        <div class="card contact-card">
          <div class="c-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="#0F6B66" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h2>{c.phoneTitle}</h2>
          <p><a href="tel:+62818533698">+62 818 533 698</a></p>
          <a class="card-link" href={wa} rel="noopener">{c.waBtn} →</a>
        </div>

        <div class="card contact-card">
          <div class="c-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="#0F6B66" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h2>{c.emailLabel}</h2>
          <p><a href="mailto:info@pupacenter.org">info@pupacenter.org</a></p>
          <h2 class="mt">{c.hoursTitle}</h2>
          <p>{c.hours}</p>
        </div>

        <div class="card contact-card">
          <div class="c-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="#0F6B66" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h2>{c.visitTitle}</h2>
          <p>{c.address.map((line) => <>{line}<br /></>)}</p>
          <a class="card-link" href="https://maps.app.goo.gl/tPCkDTf2Cf6pa3Dp7" rel="noopener">{c.mapsBtn} →</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0;border-bottom:1px solid var(--line)}
.page-head .lede{font-size:1.15rem;color:var(--ink-soft);margin:18px 0 26px}
.map-sec{padding:48px 0 8px}
.contact-grid-sec{padding:40px 0 64px}
.contact-card{align-items:flex-start}
.c-icon{width:52px;height:52px;border-radius:14px;background:var(--teal-100);display:flex;align-items:center;justify-content:center;margin-bottom:14px}
.c-icon svg{width:26px;height:26px}
.contact-card h2{font-size:1.1rem}
.contact-card .mt{margin-top:20px}
.contact-card a{min-height:auto}
.contact-grid h2{font-size:1.15rem}
.contact-grid .mt{margin-top:20px}
.contact-grid a{min-height:auto}
</style>
