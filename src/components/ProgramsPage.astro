---
import Layout from '../layouts/Layout.astro';
import { routes, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = (key: string) => (routes[key] ?? routes.home)[lang];
const wa = 'https://wa.me/62818533698';

const content = {
  en: {
    metaTitle: 'Our Programs — Mandiri, Karya & Access | PUPA Center',
    metaDescription: 'PUPA Center offers a sequence of programs for neurodivergent young adults aged 16–25 in Tangerang: Mandiri (life skills), Karya (work readiness), Access (inclusive co-working), plus extracurricular classes.',
    h1: 'Our programs',
    intro: 'Our programs form a sequence. Participants build independence first (Mandiri), then work readiness (Karya), then practice working in a real, supportive environment (Access). Each participant moves at their own pace, and extracurricular classes run alongside the main journey.',
    mandiri: {
      tag: 'Stage 1 · Life skills · Ages 16–25',
      title: 'Mandiri',
      lede: 'A comprehensive life skills and work readiness program designed to help teens and young adults maximize their potential and thrive in an inclusive society.',
      overview: 'PUPA Mandiri provides development programs for neurodivergent adolescents and adults (ages 16–25). Our primary goal is to prepare participants for independence in their daily lives, helping them optimize their personal potential and function effectively within the community. The curriculum is designed around key areas of development — from life skills through transition to work — to ensure a holistic approach to independence.',
      areasTitle: 'Curriculum areas',
      areas: [
        ['Basic living skills', 'Fundamental daily routines including self-control, communication, dressing, and personal hygiene.'],
        ['Home skills', 'Essential household activities such as housekeeping, doing the dishes, and kitchen management.'],
        ['Community participation skills', 'Social interaction skills for public spaces, covering social awareness, manners, and shopping.'],
        ['Cognitive skills', 'Basic knowledge support, including computer skills and general common knowledge.'],
        ['Independent living skills', 'Advanced independence training in self-care, organization, transportation, money management, and living with others.'],
        ['Vocational skills', 'Exploring and developing participant potential through various skills aligned with their abilities.'],
      ],
      stagesTitle: 'Our path to independence',
      stagesIntro: 'The Mandiri program is divided into three classes, allowing participants to progress at a pace suitable for their condition. Each class lasts approximately one year.',
      stages: [
        ['Life Class', 'An assisted living stage with high support (2:1 participant–mentor ratio). Participants build the foundation of independence, focusing on basic living and home skills through activities like art, physical education, and essential literacy in money, time, and communication.'],
        ['Transition Class', 'Focused on independent living, this stage expands learning into the wider community with a 5:1 ratio. The curriculum emphasizes community participation and school skills — personal growth, problem-solving, self-care, and navigating public spaces confidently.'],
        ['Independent Class', 'The transition-to-work stage prepares young adults for professional environments with a 6:1 ratio. Participants develop vocational and advanced independent living skills: work simulations, complex money management, transportation, and the social dynamics of living and working with others.'],
      ],
    },
    karya: {
      tag: 'Stage 2 · Work readiness · One year',
      title: 'Karya',
      lede: 'PUPA Karya is not about entering employment quickly, but about building strong, meaningful readiness to engage in the world of work.',
      overview: 'PUPA Karya is a one-year work readiness program designed to support neurodivergent adults in preparing for their transition into the workforce. The program focuses on self-awareness, skill development, understanding work roles, and exploring potential fields of employment.',
      blocks: [
        ['A two-phase journey', 'The first six months focus on vocational training and strengthening work-related skills through individual and group support. The following six months emphasize real-world work practice through partnerships, business units at PUPA Center, and the involvement of parents across diverse environments and roles.'],
        ['The transition from PUPA Mandiri', 'PUPA Karya serves as the natural continuation of the Mandiri program. Participants who have completed the life skills program at PUPA Mandiri may continue to Karya, with work readiness as its primary milestone.'],
        ['Eligibility and enrollment', 'Karya is also open to working-age neurodivergent individuals who did not attend PUPA Mandiri but already demonstrate a level of independence aligned with the goals of the program. We look for participants ready to explore their potential and move toward meaningful employment.'],
      ],
    },
    access: {
      tag: 'Stage 3 · Employment & community · One year, part-time',
      title: 'Access',
      lede: 'The bridge between learning and employment: a supportive work environment where neurodivergent adults grow at a pace that feels steady, respectful, and empowering.',
      overview: 'PUPA Access is the natural next step for those who have completed the Mandiri and Karya programs. After building independence skills and developing work readiness, participants enter Access ready to put those abilities into practice in a real, supportive work environment.',
      blocks: [
        ['Practice with support', 'Access offers a safe, thoughtfully structured space where participants can practice working while continuing to strengthen their skills. The environment is intentionally designed to be accommodating and responsive, helping individuals build confidence, consistency, and professional habits without the pressure often found in traditional workplaces.'],
        ['Navigating the world of work', 'Access provides optional job coaching for those who want additional guidance in their working lives. Coaching can support goal setting, communication, workplace expectations, and problem-solving — always tailored to each individual\u2019s needs and aspirations.'],
        ['Inclusive work practice', 'Access is an inclusive, sensory-considerate co-working space. Through a one-year, part-time program, participants develop consistency and collaboration without the pressure of full-time work. By partnering with families, caregivers, and organizations on real projects, Access creates a supportive ecosystem that prepares participants for meaningful employment beyond the program.'],
      ],
    },
    extra: {
      tag: 'Alongside the main journey',
      title: 'Extracurriculars',
      lede: 'Exploring interests, building skills, and expressing creativity in an inclusive environment.',
      classes: [
        ['Art', 'A public painting class led by professional art instructors in collaboration with Outsider Art — an inclusive space where participants of all backgrounds and abilities can express themselves and create meaningful works.'],
        ['Dance', 'An inclusive dance class led by professional instructors, designed to help participants express themselves, build confidence, and perform joyfully through movement.'],
        ['Barista', 'An inclusive barista class developed in collaboration with Threestori, equipping participants with practical coffee-making skills, customer service experience, and workplace readiness in a supportive, professional environment.'],
        ['Yoga (coming soon)', 'An upcoming inclusive yoga class focused on body awareness, emotional regulation, and overall well-being through guided movement and mindful practice.'],
      ],
      note: 'Every class is more than an activity — it is a space for growth, connection, and self-expression, where individuals are supported to explore their potential in a safe and inclusive environment.',
    },
    journeyTitle: 'Built For The Journey',
    journeyBody: 'Readiness doesn\u2019t happen overnight, but it does start with a single step. Whether you are looking for foundational life skills or advanced work readiness, we are here to support that transition with care, respect, and expertise. Let\u2019s explore how PUPA\u2019s integrated approach can help build the future you\u2019ve been envisioning.',
    journeyCta: 'Learn more about our approach',
    ctaTitle: 'Interested in enrolling?',
    ctaBody: 'Our enrollment process is designed to ensure the right fit for every participant. It starts with a conversation.',
    ctaEnroll: 'See how enrollment works',
  },
  id: {
    metaTitle: 'Program Kami — Mandiri, Karya & Access | PUPA Center',
    metaDescription: 'PUPA Center menawarkan rangkaian program untuk anak muda neurodivergen usia 16–25 di Tangerang: Mandiri (kecakapan hidup), Karya (kesiapan kerja), Access (co-working inklusif), serta kelas ekstrakurikuler.',
    h1: 'Program kami',
    intro: 'Program kami merupakan sebuah urutan. Peserta membangun kemandirian terlebih dahulu (Mandiri), lalu kesiapan kerja (Karya), kemudian berlatih bekerja di lingkungan nyata yang suportif (Access). Setiap peserta bergerak sesuai kecepatannya sendiri, dan kelas ekstrakurikuler berjalan berdampingan dengan perjalanan utama.',
    mandiri: {
      tag: 'Tahap 1 · Kecakapan hidup · Usia 16–25',
      title: 'Mandiri',
      lede: 'Program keterampilan hidup dan kesiapan kerja yang komprehensif ini dirancang untuk membantu individu neurodivergen dewasa dalam mengoptimalkan potensi serta berkembang di tengah masyarakat yang inklusif.',
      overview: 'PUPA Mandiri menyediakan program pendampingan kemandirian bagi individu neurodivergen dalam rentang usia 16–25 tahun (saat mendaftar). Tujuan utama program: membantu individu neurodivergen melatih kemandirian dalam kehidupan sehari-hari, mengoptimalkan potensi pribadi, dan berperan secara aktif dalam komunitas. Kurikulum kami dirancang sebagai jalur transisi terhubung, bukan layanan terpisah — setiap fase pendampingan (Life Skill hingga Transition to Work) dibangun sebagai proses yang saling terhubung.',
      areasTitle: 'Area kurikulum',
      areas: [
        ['Basic Living Skills', 'Kemampuan mengenal diri sendiri dan hal mendasar terkait rutinitas sehari-hari, seperti penguasaan diri, komunikasi, dan kebersihan diri.'],
        ['Home Skills', 'Hal rutin tentang kegiatan rumah yang dibutuhkan, seperti housekeeping, mencuci piring, dan kegiatan dapur.'],
        ['Community Participation Skills', 'Keterampilan berinteraksi sosial yang mencakup kemandirian di area umum, seperti social awareness, tata krama, dan berbelanja.'],
        ['Cognitive Skills', 'Keterampilan dasar untuk menunjang pengetahuan, seperti komputer, calistung, dan pengetahuan umum.'],
        ['Independent Living Skills', 'Pelatihan kemandirian lanjutan seperti perawatan diri, berorganisasi, transportasi, pengelolaan uang, hingga kesiapan hidup bersama orang lain.'],
        ['Vocational Skills', 'Proses mengenalkan dan menggali potensi yang dikembangkan melalui pengenalan berbagai keterampilan sesuai kebutuhan.'],
      ],
      stagesTitle: 'Jalur menuju kemandirian',
      stagesIntro: 'Program PUPA Mandiri terdiri dari tiga tahapan, memungkinkan individu neurodivergen mendaftar masuk sesuai kelompok yang tepat (selaras dengan hasil asesmen). Setiap tahap berlangsung selama satu tahun.',
      stages: [
        ['Life Class', 'Tahap kemandirian dasar bagi individu neurodivergen high-support (rasio 1:2). Terfokus pada Basic Living Skill dan Home Skill, melalui aktivitas seperti seni, gerak tubuh, serta literasi dasar (uang, waktu, dan komunikasi) guna membangun rutinitas sehari-hari.'],
        ['Transition Class', 'Tahap yang berfokus pada pengembangan keterampilan dalam interaksi sosial (rasio pendampingan 1:5). Kurikulum menekankan Community Participation Skill dan Cognitive Skill, membimbing kemampuan pemecahan masalah, perawatan diri, serta beraktivitas di ruang publik dengan percaya diri.'],
        ['Independent Class', 'Tahapan dengan gol akhir Transisi ke Dunia Kerja, mempersiapkan individu neurodivergen dalam ruang lingkup profesional (rasio pendampingan 1:6). Mengembangkan Vocational Skill dan Independent Living Skill melalui simulasi kerja, literasi keuangan, transportasi, serta dinamika sosial dalam hidup dan bekerja bersama orang lain.'],
      ],
    },
    karya: {
      tag: 'Tahap 2 · Kesiapan kerja · Satu tahun',
      title: 'Karya',
      lede: 'PUPA Karya bukan tentang cepat bekerja, namun tentang kesiapan yang matang dalam memasuki dunia kerja.',
      overview: 'PUPA Karya merupakan program kesiapan kerja berdurasi satu tahun di PUPA Center, dipersiapkan untuk mendukung individu neurodivergen dewasa dalam mempersiapkan transisi menuju dunia kerja. Fokus utama program ini adalah mengenali potensi diri, pengembangan keterampilan, pemahaman peran dalam bekerja, serta pilihan bidang bekerja.',
      blocks: [
        ['Perjalanan Dua Tahap', 'Program terbagi ke dalam dua fase terstruktur. Enam bulan pertama fokus pada pelatihan vokasional dan penguatan keterampilan kerja melalui pendampingan individu dan kelompok. Enam bulan berikutnya berfokus pada praktik kerja nyata dengan mitra, unit usaha di PUPA Center, serta dukungan orang tua dalam lingkungan dan peran yang beragam.'],
        ['Transisi PUPA Mandiri', 'PUPA Karya adalah exit plan dari PUPA Mandiri. Individu neurodivergen yang telah menyelesaikan program Life Skills di PUPA Mandiri dapat melanjutkan ke PUPA Karya sebagai program terusan dengan milestone utama: Work Readiness.'],
        ['Ketentuan Pendaftaran', 'Divisi ini juga terbuka bagi individu neurodivergen usia produktif yang belum mengikuti PUPA Mandiri, namun telah menunjukkan tingkat kemandirian sesuai tujuan Program PUPA Karya. Kami terbuka bagi individu neurodivergen yang siap mengeksplorasi potensi dan melangkah menuju pekerjaan yang bermakna.'],
      ],
    },
    access: {
      tag: 'Tahap 3 · Pekerjaan & komunitas · Satu tahun, paruh waktu',
      title: 'Access',
      lede: 'Jembatan pemahaman dan praktik terhadap dunia kerja: lingkungan latihan kerja yang kondusif, dirancang agar individu neurodivergen dapat berkembang dengan ritme yang selaras serta tepat fungsi.',
      overview: 'PUPA Access adalah langkah alami bagi individu neurodivergen yang telah menyelesaikan program PUPA Mandiri dan PUPA Karya. Setelah membangun keterampilan kemandirian dan kesiapan kerja, individu neurodivergen siap menerapkannya dalam lingkungan kerja nyata yang mendukung.',
      blocks: [
        ['Pelatihan Dengan Dukungan', 'Di PUPA Access, individu neurodivergen praktik bekerja dalam ruang yang aman dan terstruktur, sambil terus memperkuat keterampilan. Ruang lingkup kerja sengaja dirancang akomodatif dan responsif guna membantu membangun pola yang tepat, konsistensi, dan kebiasaan profesional. Pertumbuhan terjadi melalui pengalaman, refleksi, dan dukungan tepat.'],
        ['Menavigasi Dunia Kerja', 'Tersedia sesi coaching kerja bagi individu neurodivergen yang memerlukan (opsional). Pendampingan ini mendukung penetapan tujuan, komunikasi, ekspektasi di tempat kerja, dan pemecahan masalah yang disesuaikan dengan kebutuhan mendasar setiap individu. Dukungan bersifat fleksibel — membangun pembiasaan dan kepercayaan diri untuk langkah ke depan.'],
        ['Ruang Praktik Kerja Inklusif', 'PUPA Access adalah ruang kerja ramah sensorik untuk berlatih rutinitas kerja nyata, membangun kepercayaan diri, dan mengembangkan keterampilan. Melalui program paruh waktu selama satu tahun, peserta belajar konsistensi, kemandirian, dan kolaborasi tanpa tekanan kerja penuh waktu. Dengan melibatkan keluarga, pengasuh, dan mitra dalam proyek nyata, PUPA Access membangun ekosistem kerja inklusif menuju peluang kerja di masa depan.'],
      ],
    },
    extra: {
      tag: 'Berdampingan dengan perjalanan utama',
      title: 'Ekstrakurikuler',
      lede: 'Menjelajah minat, mengembangkan keterampilan, dan mengekspresikan kreativitas dalam langkah aktualisasi diri secara inklusif.',
      classes: [
        ['Art', 'Seni adalah komunikasi. Kelas melukis inklusif yang dipimpin instruktur seni profesional bekerja sama dengan Outsider Art, dirancang sebagai ruang interaksi inklusif di mana individu neurodivergen dari tingkat kemampuan yang beragam dapat mengaktualisasikan diri melalui karya seni yang bermakna.'],
        ['Dance', 'PUPA Dance dirancang dengan tujuan membantu individu neurodivergen mengekspresikan diri melalui gerak dalam ritme lagu, membangun kepercayaan diri serta koordinasi keseimbangan.'],
        ['Barista', 'Bersama Treestori, kelas barista dirancang untuk membekali individu neurodivergen dalam keterampilan praktis membuat kopi, pengalaman layanan pelanggan, dan kesiapan kerja dalam setting yang mendukung dan profesional.'],
        ['Yoga (segera hadir)', 'Kelas yoga inklusif yang akan datang, berfokus pada penyeimbangan tubuh dan pikiran, meningkatkan konsentrasi, regulasi emosi, dan rasa percaya diri dalam lingkungan yang aman dan mendukung.'],
      ],
      note: 'Setiap kegiatan bukan sekadar rutinitas, namun ruang bertumbuh nyata sebagai aktualisasi diri, di mana individu neurodivergen didukung untuk mengeksplorasi potensi mereka dalam lingkungan yang aman dan inklusif.',
    },
    journeyTitle: 'Dirancang Untuk Perjalanan',
    journeyBody: 'Kemampuan beradaptasi dan terlibat tidak terjadi dalam semalam, namun dimulai dengan satu langkah kecil. Apakah Anda mencari keterampilan hidup dasar atau kesiapan kerja tingkat lanjut bagi individu neurodivergen dewasa, kami siap mendukung transisi tersebut dengan penuh penerimaan, pemahaman, dan rasa hormat. Mari jelajahi bagaimana pendekatan terintegrasi PUPA dapat membantu membangun masa depan yang Anda impikan.',
    journeyCta: 'Pelajari pendekatan kami',
    ctaTitle: 'Tertarik untuk mendaftar?',
    ctaBody: 'Proses pendaftaran kami dirancang untuk memastikan kecocokan yang tepat bagi setiap peserta. Semuanya dimulai dari percakapan.',
    ctaEnroll: 'Lihat cara pendaftaran',
  },
};
const c = content[lang];

// Small calm icons for the six development areas (by index), stroke teal
const areaIcons = [
  '<circle cx="12" cy="8" r="4"/><path d="M5 21v-1a7 7 0 0 1 14 0v1"/>',                                  // Basic living / self
  '<path d="M3 10 12 3l9 7"/><path d="M5 9v11h14V9"/><path d="M9 20v-6h6v6"/>',                             // Home
  '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="10" r="2.5"/><path d="M3 20v-1a6 6 0 0 1 12 0v1"/><path d="M15 20v-1a4 4 0 0 1 6 0v1"/>', // Community
  '<path d="M12 3a7 7 0 0 0-4 12.7V18h8v-2.3A7 7 0 0 0 12 3z"/><path d="M9 21h6"/>',                        // Cognitive (lightbulb)
  '<path d="M6 3v18"/><path d="M6 4h9l-1.5 3L15 10H6"/>',                                                   // Independent (flag/goal)
  '<path d="M4 7h16v13H4z"/><path d="M9 7V4h6v3"/><path d="M4 13h16"/>',                                    // Vocational (briefcase)
];
const sections = [
  { id: 'mandiri', d: c.mandiri, img: '/images/a6701241.jpg' },
  { id: 'karya', d: c.karya, img: '/images/a6701088.jpg' },
  { id: 'access', d: c.access, img: '/images/a6701700.jpg' },
];
const extraImgs: Record<string, string> = {
  0: '/images/a6701624.jpg',   // Art
  1: '/images/a6702069.jpg',   // Dance
  2: '/images/a6701212.jpg',   // Barista
};
---
<Layout lang={lang} routeKey="programs" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
      <p class="lede">{c.intro}</p>
    </div>
  </section>

  {sections.map((s, i) => (
    <section class={`program ${i % 2 ? 'alt' : ''}`} id={s.id}>
      <div class="wrap">
        <div class="prog-intro">
          <div>
            <span class="eyebrow">{s.d.tag}</span>
            <h2>{s.d.title}</h2>
            <p class="prog-lede">{s.d.lede}</p>
            <p>{s.d.overview}</p>
          </div>
          <img class="blob prog-photo" src={s.img} alt="" loading="lazy" width="480" height="420" />
        </div>

        {'areas' in s.d && (
          <>
            <h3>{s.d.areasTitle}</h3>
            <div class="card-grid areas">
              {s.d.areas.map((a: string[], ai: number) => (
                <div class="card icon-card">
                  <span class="mini-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={areaIcons[ai % areaIcons.length]}></svg></span>
                  <h4>{a[0]}</h4><p>{a[1]}</p>
                </div>
              ))}
            </div>
            <h3>{s.d.stagesTitle}</h3>
            <p>{s.d.stagesIntro}</p>
            <div class="card-grid">
              {s.d.stages.map((st: string[], n: number) => (
                <div class="card num-card"><span class="stage-badge">{n + 1}</span><h4>{st[0]}</h4><p>{st[1]}</p></div>
              ))}
            </div>
          </>
        )}
        {'blocks' in s.d && (
          <div class="card-grid">
            {s.d.blocks.map((b: string[]) => (
              <div class="card"><h4>{b[0]}</h4><p>{b[1]}</p></div>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}

  <section class="program alt" id="extracurriculars">
    <div class="wrap">
      <span class="eyebrow">{c.extra.tag}</span>
      <h2>{c.extra.title}</h2>
      <p class="prog-lede">{c.extra.lede}</p>
      <div class="card-grid areas extra-grid">
        {c.extra.classes.map((cl, i) => (
          <div class="card photo-card">
            {extraImgs[i]
              ? <img src={extraImgs[i]} alt="" loading="lazy" width="360" height="220" />
              : <div class="yoga-ph" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2"/><path d="M12 8v6"/><path d="M5 21c2-3 4.5-4.5 7-4.5S17 18 19 21"/><path d="M4 12c3 1.5 5.5 2 8 2s5-.5 8-2"/></svg>
                </div>}
            <div class="photo-card-body"><h4>{cl[0]}</h4><p>{cl[1]}</p></div>
          </div>
        ))}
      </div>
      <p>{c.extra.note}</p>
    </div>
  </section>

  <section class="journey-band">
    <div class="wrap journey-grid">
      <h2 class="journey-title">{c.journeyTitle}</h2>
      <div>
        <p class="journey-body">{c.journeyBody}</p>
        <a class="btn btn-primary" href={p('about') + '#approach-detail'}>{c.journeyCta}</a>
      </div>
    </div>
  </section>

  <section class="prog-cta">
    <div class="wrap">
      <h2>{c.ctaTitle}</h2>
      <p>{c.ctaBody}</p>
      <a class="btn btn-primary" href={p('enrollment')}>{c.ctaEnroll}</a>
    </div>
  </section>
</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid var(--line)}
.page-head .lede{font-size:1.15rem;color:var(--ink-soft);margin-top:18px}
.program{padding:64px 0}
.program.alt{background:var(--surface);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.prog-lede{font-size:1.15rem;color:var(--ink-soft);margin:14px 0 18px}
.program h3{margin:36px 0 14px}
.program h4{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:600}
.card-grid{margin-top:18px}
.areas{grid-template-columns:repeat(3,1fr)}
.stage-badge{display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;background:var(--orange-500);color:#2B1503;font-family:'Fraunces',serif;font-weight:700}
.prog-intro{display:grid;grid-template-columns:1.2fr .8fr;gap:44px;align-items:center}
.prog-photo{width:100%;aspect-ratio:8/7;box-shadow:0 14px 34px rgba(11,68,65,.12)}
.extra-grid{grid-template-columns:repeat(2,1fr);gap:24px;grid-auto-rows:1fr}
.photo-card{padding:0;overflow:hidden;display:flex;flex-direction:row}
.photo-card img{width:40%;flex:none;aspect-ratio:auto;object-fit:cover}
.photo-card-body{padding:22px 24px;display:flex;flex-direction:column;flex-grow:1;justify-content:center}
.yoga-ph{width:40%;flex:none;display:flex;align-items:center;justify-content:center;background:linear-gradient(150deg,var(--sage),var(--peach));color:var(--teal-700)}
.yoga-ph svg{width:44px;height:44px;opacity:.75}
.journey-band{background:var(--cream);border-top:1px solid #EFE4D2;border-bottom:1px solid #EFE4D2;padding:80px 0}
.journey-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.journey-title{font-size:clamp(2.2rem,5vw,3.6rem);color:var(--teal-700);line-height:1.08;position:relative;display:inline-block}
.journey-title::after{content:"";display:block;width:64%;height:6px;border-radius:4px;background:var(--orange-500);margin-top:12px;transform:rotate(-1.2deg)}
.journey-body{color:var(--teal-700);margin-bottom:26px}
@media (max-width:960px){.journey-grid{grid-template-columns:1fr}}
.prog-cta{padding:72px 0;text-align:left}
.prog-cta p{color:var(--ink-soft);margin:14px 0 26px}
.cta-row{display:flex;flex-wrap:wrap;gap:14px}
