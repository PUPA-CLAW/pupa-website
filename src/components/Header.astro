---
import { useTranslations, routes, type Lang } from '../i18n/ui';
interface Props { lang: Lang; routeKey: string; altRoute?: { en: string; id: string; ko: string }; }
const { lang, routeKey, altRoute } = Astro.props;
const t = useTranslations(lang);
const other: Lang = lang === 'en' ? 'id' : 'en';
const route = altRoute ?? (routes[routeKey] ?? routes.home);
const p = (key: string) => (routes[key] ?? routes.home)[lang];

const menu = [
  { label: t('nav.about'), href: p('about'), children: [
    { label: t('nav.about.story'), href: p('about') + '#story' },
    { label: t('nav.about.mission'), href: p('about') + '#mission' },
    { label: t('nav.about.board'), href: p('board') },
    { label: t('nav.about.team'), href: p('team') },
    { label: t('nav.about.approach'), href: p('about') + '#approach' },
  ]},
  { label: t('nav.programs'), href: p('programs'), children: [
    { label: t('nav.programs.overview'), href: p('programs') },
    { label: t('nav.programs.mandiri'), href: p('programs') + '#mandiri' },
    { label: t('nav.programs.karya'), href: p('programs') + '#karya' },
    { label: t('nav.programs.access'), href: p('programs') + '#access' },
    { label: t('nav.programs.extracurriculars'), href: p('programs') + '#extracurriculars' },
    { label: t('nav.programs.workshops'), href: p('workshops') },
  ]},
  { label: t('nav.enrollment'), href: p('enrollment'), children: [
    { label: t('nav.enrollment.how'), href: p('enrollment') },
    { label: t('nav.enrollment.faq'), href: p('enrollment') + '#faq' },
    { label: t('nav.enrollment.visit'), href: p('contact') },
  ]},
  { label: t('nav.involved'), href: p('getInvolved'), children: [
    { label: t('nav.involved.volunteer'), href: p('getInvolved') + '#volunteer' },
    { label: t('nav.involved.careers'), href: p('getInvolved') + '#careers' },
    { label: t('nav.involved.partner'), href: p('getInvolved') + '#partner' },
  ]},
  { label: t('nav.resources'), href: p('resources'), children: [
    { label: t('nav.resources.news'), href: p('resources') + '#news' },
    { label: t('nav.resources.parents'), href: p('blog') },
    { label: t('nav.resources.stories'), href: p('stories') },
  ]},
  { label: t('nav.contact'), href: p('contact'), children: [] },
];
---
<header class="site-header">
  <div class="wrap topbar">
    <a class="logo" href={routes.home[lang]} aria-label="PUPA Center — home">
      <img class="logo-img" src="/images/brand/pupa-logo.svg" alt="PUPA" width="120" height="80" />
    </a>

    <nav class="primary" aria-label={t('a11y.mainnav')}>
      <ul>
        {menu.map((item) => (
          <li class={item.children.length ? 'has-children' : ''}>
            <a href={item.href}>{item.label}{item.children.length > 0 && <span class="caret" aria-hidden="true">▾</span>}</a>
            {item.children.length > 0 && (
              <ul class="dropdown">
                {item.children.map((c) => <li><a href={c.href}>{c.label}</a></li>)}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <div class="lang-menu" data-lang-menu>
        <button class="lang-btn" type="button" aria-expanded="false" aria-haspopup="true" aria-controls="lang-list" aria-label="Language / Bahasa / 언어">
          <svg class="globe-ic" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <path d="M12 3c2.6 2.7 2.6 15.3 0 18M12 3c-2.6 2.7-2.6 15.3 0 18" />
          </svg>
          <span class="lang-code">{lang.toUpperCase()}</span>
          <span class="caret" aria-hidden="true">▾</span>
        </button>
        <ul class="lang-list" id="lang-list">
          <li><a href={route.id} lang="id" aria-current={lang === 'id' ? 'true' : undefined}>Indonesia</a></li>
          <li><a href={route.en} lang="en" aria-current={lang === 'en' ? 'true' : undefined}>English</a></li>
          <li><a href={route.ko} lang="ko" aria-current={lang === 'ko' ? 'true' : undefined}>한국어</a></li>
        </ul>
      </div>

      <a class="btn-donate-header" href={routes.donate[lang]}>{t('nav.donate')}</a>
    </div>

    <button class="menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label={t('nav.menu')} data-menu-toggle>
      <span class="menu-icon" aria-hidden="true"></span>
    </button>
  </div>
</header>

<div class="nav-backdrop" data-menu-close aria-hidden="true"></div>

<nav class="mobile-drawer" id="mobile-nav" aria-label={t('a11y.mainnav')}>
  <ul class="drawer-list">
    {menu.map((item, i) => (
      <li class={item.children.length ? 'has-sub' : ''}>
        {item.children.length > 0 ? (
          <Fragment>
            <button type="button" class="drawer-head" aria-expanded="false" aria-controls={`acc-${i}`} data-acc-toggle>
              <span class="acc-label">{item.label}</span>
              <span class="acc-chev" aria-hidden="true">▾</span>
            </button>
            <ul class="drawer-sub" id={`acc-${i}`}>
              {item.children.map((c) => <li><a href={c.href}>{c.label}</a></li>)}
            </ul>
          </Fragment>
        ) : (
          <a class="drawer-link" href={item.href}>{item.label}</a>
        )}
      </li>
    ))}
  </ul>
</nav>

<style>
.site-header{background:var(--surface);border-bottom:1px solid var(--line);position:sticky;top:0;z-index:60}
.topbar{display:flex;align-items:center;gap:16px;min-height:76px}
.logo{display:flex;align-items:center;text-decoration:none;min-height:44px}
.logo-img{height:76px;width:auto}

nav.primary{margin-left:auto}
nav.primary > ul{display:flex;list-style:none;gap:2px}
nav.primary a{display:flex;align-items:center;min-height:44px;padding:10px 11px;font-size:1rem;font-weight:500;color:var(--ink);text-decoration:none;border-radius:10px}
nav.primary a:hover, nav.primary li:focus-within > a{background:var(--teal-050)}
nav.primary li{position:relative}
.caret{margin-left:6px;font-size:.7em;color:var(--ink-soft)}
.dropdown{position:absolute;top:100%;left:0;min-width:240px;background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:8px;list-style:none;display:none}
nav.primary li:hover > .dropdown, nav.primary li:focus-within > .dropdown{display:block}
.dropdown a{width:100%;border-radius:10px}

.header-actions{display:flex;align-items:center;gap:10px}
.lang-menu{position:relative}
.lang-btn{display:inline-flex;align-items:center;gap:5px;min-height:40px;padding:0 12px;border:1.5px solid var(--line);border-radius:999px;background:var(--surface);color:var(--ink);font-size:.9rem;font-weight:600;font-family:inherit;cursor:pointer}
.lang-btn:hover{background:var(--teal-050)}
.lang-btn .globe-ic{color:var(--teal-700)}
.lang-btn .caret{margin-left:2px;color:var(--ink-soft)}
.lang-list{position:absolute;top:calc(100% + 6px);right:0;min-width:154px;background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:6px;margin:0;list-style:none;display:none;z-index:70}
.lang-menu.open .lang-list{display:block}
.lang-list a{display:block;padding:9px 12px;border-radius:8px;font-size:.95rem;font-weight:500;color:var(--ink);text-decoration:none}
.lang-list a:hover{background:var(--teal-050)}
.lang-list a[aria-current="true"]{background:var(--teal-050);color:var(--teal-700)}
.btn-donate-header{display:inline-flex;align-items:center;justify-content:center;min-height:40px;padding:0 18px;border-radius:999px;background:var(--orange-700);color:#fff;font-size:.9rem;font-weight:600;text-decoration:none;transition:background .2s ease}
.btn-donate-header:hover{background:#93441A}

.menu-btn{display:none;width:44px;height:44px;padding:0;background:transparent;color:var(--ink);border:none;border-radius:10px;cursor:pointer}
.menu-btn:hover{background:var(--teal-050)}
.menu-icon,.menu-icon::before,.menu-icon::after{display:block;width:24px;height:2px;background:currentColor;border-radius:2px;transition:transform .2s ease,opacity .2s ease}
.menu-icon{position:relative}
.menu-icon::before{content:"";position:absolute;left:0;top:-7px}
.menu-icon::after{content:"";position:absolute;left:0;top:7px}
.menu-btn[aria-expanded="true"] .menu-icon{background:transparent}
.menu-btn[aria-expanded="true"] .menu-icon::before{transform:translateY(7px) rotate(45deg)}
.menu-btn[aria-expanded="true"] .menu-icon::after{transform:translateY(-7px) rotate(-45deg)}

.nav-backdrop{display:none}
.mobile-drawer{display:none}

@media (max-width:1160px){
  nav.primary{display:none}
  .menu-btn{display:inline-flex;align-items:center;justify-content:center;order:3;margin-left:0}
  .header-actions{margin-left:auto;order:2}
  .logo-img{height:54px}

  /* Dim the page behind the menu; the header stays bright on top */
  .nav-backdrop{display:block;position:fixed;inset:0;background:rgba(0,0,0,.45);opacity:0;visibility:hidden;transition:opacity .24s ease,visibility 0s linear .24s;z-index:40}
  html.menu-open, html.menu-open body{overflow:hidden}
  html.menu-open .nav-backdrop{opacity:1;visibility:visible;transition:opacity .24s ease}

  /* Right-side slide-in drawer, sitting just below the 76px header */
  .mobile-drawer{display:block;position:fixed;top:76px;right:0;bottom:0;width:82%;max-width:360px;background:var(--surface);border-left:1px solid var(--line);box-shadow:-8px 0 24px rgba(0,0,0,.12);z-index:50;overflow-y:auto;overscroll-behavior:contain;-webkit-overflow-scrolling:touch;transform:translateX(100%);visibility:hidden;transition:transform .24s ease,visibility 0s linear .24s;padding:14px 0 28px}
  .mobile-drawer.open{transform:translateX(0);visibility:visible;transition:transform .24s ease}
  .drawer-list{list-style:none;margin:0;padding:0}
  .drawer-list > li{border-bottom:1px solid var(--line)}
  .drawer-list > li:last-child{border-bottom:none}
  /* Section heading (accordion toggle) and childless links share the row look */
  .drawer-head,.drawer-link{display:flex;align-items:center;width:100%;padding:16px 22px;font-size:1.05rem;font-weight:600;color:var(--ink);text-decoration:none;background:none;border:none;font-family:inherit;cursor:pointer;text-align:left}
  .drawer-head{justify-content:space-between}
  .drawer-head:hover,.drawer-link:hover{background:var(--teal-050)}
  .acc-chev{color:var(--ink-soft);font-size:.8em;transition:transform .25s ease}
  .drawer-list > li.open .drawer-head{color:var(--teal-700)}
  .drawer-list > li.open .acc-chev{transform:rotate(180deg);color:var(--teal-700)}
  /* Sub-links stay collapsed until their section is opened */
  .drawer-sub{list-style:none;margin:0;padding:0;max-height:0;overflow:hidden;transition:max-height .3s ease;background:#fbfcfb}
  .drawer-list > li.open .drawer-sub{max-height:520px}
  .drawer-sub a{display:block;padding:11px 22px 11px 34px;font-size:.95rem;font-weight:500;color:var(--ink-soft);text-decoration:none}
  .drawer-sub a:hover{background:var(--teal-050);color:var(--ink)}
  .drawer-sub li:last-child a{padding-bottom:14px}
}
@media (max-width:560px){
  .topbar{gap:8px}
  .header-actions{order:2;gap:8px}
  .menu-btn{order:3}
  .lang-btn{padding:0 10px}
  .btn-donate-header{padding:0 14px}
}
</style>

<script>
  // Mobile: hamburger opens a right-side drawer; header stays put on top.
  const btn = document.querySelector('[data-menu-toggle]');
  const drawer = document.getElementById('mobile-nav');
  const closers = document.querySelectorAll('[data-menu-close]');
  // Globe language dropdown.
  const langMenu = document.querySelector('[data-lang-menu]');
  const langBtn = langMenu?.querySelector('.lang-btn');

  const setMenu = (open: boolean) => {
    drawer?.classList.toggle('open', open);
    btn?.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.documentElement.classList.toggle('menu-open', open);
    if (!open) {
      // Collapse any open section so the drawer always reopens tidy.
      drawer?.querySelectorAll('.drawer-list > li.open').forEach((o) => {
        o.classList.remove('open');
        o.querySelector('[data-acc-toggle]')?.setAttribute('aria-expanded', 'false');
      });
    }
  };
  const setLang = (open: boolean) => {
    langMenu?.classList.toggle('open', open);
    langBtn?.setAttribute('aria-expanded', open ? 'true' : 'false');
  };

  // Opening one closes the other.
  btn?.addEventListener('click', () => {
    const open = !drawer?.classList.contains('open');
    if (open) setLang(false);
    setMenu(open);
  });
  // Tapping the dimmed backdrop closes the drawer.
  closers.forEach((el) => el.addEventListener('click', () => setMenu(false)));
  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = !langMenu?.classList.contains('open');
    if (open) setMenu(false);
    setLang(open);
  });

  // Escape closes both; a click outside the language menu closes it.
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { setMenu(false); setLang(false); } });
  document.addEventListener('click', (e) => {
    if (langMenu && !langMenu.contains(e.target as Node)) setLang(false);
  });
  // Close the drawer when a link inside it is tapped.
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  // Accordion: tapping a section heading expands it and collapses the others.
  drawer?.querySelectorAll('[data-acc-toggle]').forEach((tgl) => {
    tgl.addEventListener('click', () => {
      const li = tgl.parentElement;
      const wasOpen = li?.classList.contains('open');
      drawer?.querySelectorAll('.drawer-list > li.open').forEach((o) => {
        o.classList.remove('open');
        o.querySelector('[data-acc-toggle]')?.setAttribute('aria-expanded', 'false');
      });
      if (!wasOpen) {
        li?.classList.add('open');
        tgl.setAttribute('aria-expanded', 'true');
      }
    });
  });
  // Remember an explicit language choice so the homepage never overrides it.
  document.querySelectorAll('.lang-menu a').forEach((a) => {
    a.addEventListener('click', () => {
      try { localStorage.setItem('pupa-lang', a.getAttribute('lang') || ''); } catch {}
    });
  });
</script>
