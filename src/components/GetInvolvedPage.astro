---
import Layout from '../layouts/Layout.astro';
import { type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const wa = 'https://wa.me/62818533698';

const content = {
  en: {
    metaTitle: 'Get Involved — Volunteer, Careers & Partnerships | PUPA Center',
    metaDescription: 'Support neurodivergent young adults in Tangerang: volunteer your skills at PUPA Center, join our team, or partner with us as a company or organization.',
    h1: 'Get Involved',
    intro: 'There are three main ways to support our work: volunteer your time and skills, join our team, or partner with us as an organization.',
    sections: [
      { id: 'volunteer', title: 'Volunteer', body: 'If you have creative ideas you would like to share with PUPA Center participants, join our volunteer program. We welcome individuals, communities, and organizations to share their knowledge and skills through workshop and sharing sessions — from arts and crafts to vocational skills and everyday life topics.', cta: 'Volunteer — message us on WhatsApp', href: wa },
      { id: 'careers', title: 'Careers & Internships', body: 'If you share our vision of supporting neurodivergent individuals and want to join the professional team at PUPA Center, send your CV and application letter with the subject "Job Application" (stating the position). We also offer internship opportunities for university students in education or psychology to gain experience as teacher assistants — available at certain times, with the subject "Internship Application".', cta: 'Email your CV to info@pupacenter.org', href: 'mailto:info@pupacenter.org' },
      { id: 'partner', title: 'Partner with Us', body: 'Companies and organizations can partner with PUPA Center through internships and job placements for our Access participants, CSR programs, collaborative projects, and inclusive hiring initiatives.', cta: 'Discuss a partnership — email us', href: 'mailto:info@pupacenter.org' },
    ],
  },
  id: {
    metaTitle: 'Ikut Terlibat — Relawan, Karier & Kemitraan | PUPA Center',
    metaDescription: 'Dukung anak muda neurodivergen di Tangerang: menjadi relawan di PUPA Center, bergabung dengan tim kami, atau bermitra sebagai perusahaan atau organisasi.',
    h1: 'Ikut Terlibat',
    intro: 'Ada tiga cara utama untuk mendukung kerja kami: menjadi relawan dengan waktu dan keahlian Anda, bergabung dengan tim kami, atau bermitra sebagai organisasi.',
    sections: [
      { id: 'volunteer', title: 'Menjadi relawan', body: 'Jika Anda memiliki ide kreatif yang ingin dibagikan kepada peserta PUPA Center, bergabunglah dengan program relawan kami. Kami menyambut individu, komunitas, dan organisasi untuk berbagi pengetahuan dan keterampilan melalui sesi lokakarya dan berbagi — dari seni dan kerajinan hingga keterampilan vokasional dan topik kehidupan sehari-hari.', cta: 'Menjadi relawan — hubungi kami via WhatsApp', href: wa },
      { id: 'careers', title: 'Karier & Magang', body: 'Jika Anda memiliki visi yang sama dalam mendampingi individu neurodivergen dan ingin bergabung dengan tim profesional PUPA Center, kirimkan CV dan surat lamaran dengan subjek "Job Application" (mencantumkan posisi yang dilamar). Kami juga menyediakan kesempatan magang bagi mahasiswa bidang pendidikan atau psikologi untuk mendapatkan pengalaman sebagai asisten pengajar — tersedia pada waktu tertentu, dengan subjek "Internship Application".', cta: 'Kirim CV ke info@pupacenter.org', href: 'mailto:info@pupacenter.org' },
      { id: 'partner', title: 'Bermitra dengan kami', body: 'Perusahaan dan organisasi dapat bermitra dengan PUPA Center melalui magang dan penempatan kerja bagi peserta Access, program CSR, proyek kolaboratif, dan inisiatif perekrutan inklusif.', cta: 'Diskusikan kemitraan — email kami', href: 'mailto:info@pupacenter.org' },
    ],
  },
  ko: {
    metaTitle: '함께하기 — 자원봉사, 채용, 파트너십 | PUPA Center',
    metaDescription: '탕에랑의 신경다양성 청년을 응원해 주세요: PUPA 센터에서 재능을 나누는 자원봉사, 팀 합류, 또는 기업·기관 파트너십.',
    h1: '함께하기',
    intro: '우리의 일을 응원하는 방법은 크게 세 가지입니다: 시간과 재능을 나누는 자원봉사, 팀에 합류하기, 그리고 기관으로서 파트너가 되기.',
    sections: [
      { id: 'volunteer', title: '자원봉사', body: 'PUPA 센터 참여자들과 나누고 싶은 창의적인 아이디어가 있다면 자원봉사 프로그램에 함께해 주세요. 미술·공예부터 직업 기술, 일상생활 주제까지 — 워크숍과 나눔 세션을 통해 지식과 기술을 나눠 줄 개인, 커뮤니티, 기관을 환영합니다.', cta: '자원봉사 문의 — WhatsApp으로 연락하기', href: wa },
      { id: 'careers', title: '채용과 인턴십', body: '신경다양인을 지원하는 우리의 비전에 공감하고 PUPA 센터의 전문 팀에 합류하고 싶다면, \'Job Application\'(지원 직무 명시)이라는 제목으로 CV와 지원서를 보내 주세요. 교육학·심리학 전공 대학생을 위한 교사 보조 인턴십도 특정 시기에 운영합니다 — 제목은 \'Internship Application\'으로 보내 주세요.', cta: 'info@pupacenter.org 로 CV 보내기', href: 'mailto:info@pupacenter.org' },
      { id: 'partner', title: '파트너십', body: '기업과 기관은 Access 참여자를 위한 인턴십과 취업 연계, CSR 프로그램, 협력 프로젝트, 포용적 채용 이니셔티브를 통해 PUPA 센터와 파트너가 될 수 있습니다.', cta: '파트너십 논의 — 이메일 보내기', href: 'mailto:info@pupacenter.org' },
    ],
  },
};
const c = content[lang] ?? content.en;
const giImgs = ['/images/volunteer.jpg', '/images/careers-internship.jpg', '/images/pupa-group-9678.jpg'];
---
<Layout lang={lang} routeKey="getInvolved" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
      <p class="lede">{c.intro}</p>
    </div>
  </section>

  {c.sections.map((s, i) => (
    <section class={`gi-sec ${i % 2 ? 'alt' : ''}`} id={s.id}>
      <div class="wrap gi-grid">
        <div>
          <h2>{s.title}</h2>
          <p class="gi-body">{s.body}</p>
          <a class="btn btn-primary" href={s.href} rel="noopener">{s.cta}</a>
        </div>
        <img class={i % 2 ? 'blob-alt gi-photo' : 'blob gi-photo'} src={giImgs[i]} alt="" loading="lazy" width="420" height="360" />
      </div>
    </section>
  ))}
</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid var(--line)}
.page-head .lede{font-size:1.15rem;color:var(--ink-soft);margin-top:18px}
.gi-sec{padding:56px 0}
.gi-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:44px;align-items:center}
.gi-photo{width:100%;aspect-ratio:8/7}
@media (max-width:960px){.gi-grid{grid-template-columns:1fr}}
.gi-sec.alt{background:var(--surface);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.gi-body{color:var(--ink-soft);margin:14px 0 26px}
</style>
