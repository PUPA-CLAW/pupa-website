---
import Layout from '../layouts/Layout.astro';
import { routes, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = (key: string) => (routes[key] ?? routes.home)[lang];
const wa = 'https://wa.me/62818533698';

const content = {
  en: {
    metaTitle: 'Enrollment — How to Join PUPA Center',
    metaDescription: 'PUPA Center\u2019s enrollment process for neurodivergent young adults aged 16–25: initial contact, introduction session, onsite visit, assessment, and a 1–3 month probation period to ensure the right program fit.',
    h1: 'Enrollment',
    intro: 'Our enrollment process is designed to ensure the right fit for every participant. Through an initial introduction and assessment period, we take time to understand individual needs, goals, and readiness before placement into our programs. Registration is open year-round.',
    stepsTitle: 'The enrollment process, step by step',
    steps: [
      ['Contact the PUPA admin', 'Parents contact the PUPA admin to receive initial information.'],
      ['PUPA introduction session', 'Parents are introduced to PUPA through a video or virtual meeting.'],
      ['Onsite visit', 'Parents and the prospective participant visit PUPA to experience the environment firsthand.'],
      ['Enrollment form submission', 'Parents complete the enrollment form and submit psychological and/or IQ assessment results from the past two years.'],
      ['Probation schedule', 'PUPA confirms and shares the probation schedule once all documents are received.'],
      ['Probation period', 'The prospective participant takes part in a 1–3 month probation period.'],
      ['Parent counseling', 'Parents attend one counseling session with a PUPA Center counselor.'],
      ['Evaluation meeting', 'Parents meet with the PUPA team to discuss the probation evaluation results.'],
      ['Enrollment decision', 'Ready for enrollment: parents receive an offering letter. Further preparation required: parents receive a detailed evaluation report with recommendations and guidance.'],
    ],
    ctaStart: 'Start with step 1 — message us on WhatsApp',
    faqTitle: 'Frequently asked questions',
    faq: [
      ['What is PUPA Center?', 'PUPA Center is a development center focused on life skills and work readiness for neurodivergent individuals, particularly adolescents and young adults. The program is delivered through structured and practical programs.'],
      ['Is PUPA Center a school?', 'No. PUPA Center is a development and support center rather than a formal school. Our programs do not follow an academic school curriculum.'],
      ['Is PUPA Center a therapy center?', 'No. PUPA Center does not provide therapy services. Instead, we focus on developing life skills and independence for neurodivergent individuals through structured, supportive activities.'],
      ['Who can participate in PUPA Center programs?', 'Our programs are intended for neurodivergent adolescents and adults, including individuals on the autism spectrum. Participation is determined through eligibility criteria and an initial assessment process.'],
      ['What programs are offered at PUPA Center?', 'PUPA Center offers programs including life skills development, work readiness skills, social and communication skills, functional activities, and practice-based learning experiences (experiential learning).'],
      ['What is the age requirement to enroll?', 'PUPA Center accepts participants between the ages of 16 and 25.'],
      ['Is there an assessment before joining?', 'Yes. All prospective participants undergo a probation period to help determine their individual needs, goals, and the most suitable program placement.'],
      ['Can participants be accompanied by a shadow teacher?', 'Participants receive support from PUPA Center supervisors during activities. Shadow teachers are not permitted to enter the classroom.'],
      ['Does PUPA Center offer job placement or internships?', 'PUPA Center offers programs that introduce participants to the world of work and provide practical experience, but employment placement is not guaranteed.'],
      ['How does communication with parents work?', 'We maintain regular communication with parents through dedicated applications, progress reports, and ongoing discussions with the PUPA Center team.'],
      ['Are there activities outside of PUPA Center?', 'Yes. Participants may take part in outings, social activities, and experience-based projects, depending on the program and scheduled timeline.'],
      ['How can I enroll?', 'To register, please contact the PUPA Center admin for more detailed information.'],
      ['What is the activity schedule?', 'Activities take place five days a week, Monday through Friday, from 9:00 AM to 3:00 PM (WIB).'],
      ['Will participants get a job after completing a program?', 'PUPA Center does not guarantee job placement. However, our programs are designed to equip participants with work-related skills, work habits, and relevant practical experience as preparation for employment or other productive activities.'],
      ['My child is non-verbal. Can they participate?', 'PUPA Center is open to individuals with a wide range of support needs. Program suitability for non-verbal participants is determined through an initial assessment to understand their needs, abilities, and the type of support required.'],
      ['How are classes structured, considering the diversity of the autism spectrum?', 'To accommodate diverse needs, PUPA Center conducts a 1–3 month probation period during which assessments and observations are carried out. Participants are then grouped into classes based on similar developmental phases and learning paces.'],
      ['Can registration be done at any time?', 'Yes, registration is open year-round. PUPA Center organizes its programs into three terms each year. Participants who join between January and June may enter an ongoing program, with any missed content adjusted through an Individualized Education Plan (IEP). Participants who join between July and December will repeat the program package in the following year, as more than 50% of the program content has already been completed.'],
    ],
  },
  id: {
    metaTitle: 'Pendaftaran — Cara Bergabung dengan PUPA Center',
    metaDescription: 'Proses pendaftaran PUPA Center untuk anak muda neurodivergen usia 16–25: kontak awal, sesi perkenalan, kunjungan langsung, asesmen, dan masa probation 1–3 bulan untuk memastikan penempatan program yang tepat.',
    h1: 'Pendaftaran',
    intro: 'Proses pendaftaran PUPA dirancang untuk memastikan kesesuaian kebutuhan bagi setiap individu. Melalui tahap pengenalan dan observasi awal, kami fokus untuk memahami kesiapan setiap individu, kebutuhan, serta tujuan bergabung sebelum terdaftar sebagai peserta dalam program kami. Pendaftaran dibuka sepanjang tahun.',
    stepsTitle: 'Proses pendaftaran, langkah demi langkah',
    steps: [
      ['Menghubungi PUPA', 'Orang tua menghubungi Admin PUPA untuk mendapatkan informasi awal.'],
      ['Informasi Program', 'Orang tua akan mendapatkan penjelasan mengenai PUPA melalui video atau pertemuan virtual.'],
      ['Kunjungan PUPA Center', 'Orang tua dan calon peserta berkunjung ke PUPA untuk melihat dan merasakan langsung lingkungan PUPA Center.'],
      ['Pendaftaran', 'Orang tua mengisi formulir pendaftaran serta melampirkan hasil asesmen psikologi dan/atau tes IQ dalam dua tahun terakhir.'],
      ['Jadwal Probation', 'PUPA akan mengonfirmasi dan membagikan jadwal probation setelah seluruh dokumen diterima.'],
      ['Probation', 'Calon peserta mengikuti masa probation selama 1–3 bulan.'],
      ['Sesi Konseling', 'Orang tua mengikuti satu sesi konseling bersama konselor PUPA Center.'],
      ['Evaluasi', 'Orang tua bertemu dengan tim PUPA untuk membahas hasil evaluasi selama masa probation.'],
      ['Hasil', 'Siap untuk diterima: orang tua akan menerima Offer Letter (surat penerimaan). Diperlukan persiapan lebih lanjut: orang tua akan menerima laporan evaluasi menyeluruh beserta rekomendasi lanjutan.'],
    ],
    ctaStart: 'Mulai dari langkah 1 — hubungi kami via WhatsApp',
    faqTitle: 'Pertanyaan yang sering diajukan',
    faq: [
      ['Apa itu PUPA Center?', 'PUPA Center adalah pusat pengembangan keterampilan hidup dan kesiapan kerja bagi individu neurodivergen, khususnya remaja dan dewasa muda. Program pendampingan disampaikan secara terstruktur dan praktis, sehingga setiap peserta dapat belajar dan mempraktikkan setiap landasan teori sesuai tahap yang diperlukan.'],
      ['Apakah PUPA Center sebuah sekolah?', 'Bukan. PUPA Center adalah pusat pengembangan dan pendampingan (lembaga informal), bukan sekolah formal. Program-program kami tidak mengikuti kurikulum akademik sekolah, melainkan dirancang untuk mengembangkan keterampilan hidup dan kesiapan kerja secara praktis khusus bagi individu neurodivergen.'],
      ['Apakah PUPA Center pusat terapi?', 'Bukan. PUPA Center bukan tempat terapi. Kami fokus pada pengembangan keterampilan hidup dan kemandirian bagi individu neurodivergen melalui kegiatan yang terstruktur dan suportif.'],
      ['Siapa yang dapat mengikuti program PUPA Center?', 'Program PUPA Center ditujukan untuk remaja dan dewasa neurodivergen, termasuk individu dengan spektrum autisme, sesuai dengan kriteria dan asesmen awal.'],
      ['Program apa saja yang tersedia di PUPA Center?', 'Program PUPA Center mencakup pengembangan kemandirian (keterampilan hidup), kesiapan kerja, keterampilan sosial dan komunikasi, aktivitas fungsional, serta pengalaman belajar berbasis praktik (experiential learning).'],
      ['Berapa usia yang dipersyaratkan untuk mendaftar?', 'Syarat usia peserta PUPA Center antara 16 hingga 25 tahun (saat mendaftar).'],
      ['Apakah ada asesmen sebelum bergabung?', 'Ya. Setiap calon peserta akan melalui masa probation untuk menentukan kebutuhan, tujuan, dan penempatan program yang sesuai.'],
      ['Apakah peserta dapat didampingi guru pendamping (shadow teacher)?', 'Pendampingan peserta dilakukan langsung oleh Supervisor PUPA Center. Apabila dirasa perlu, pendamping dapat menunggu dalam jarak dekat, namun tidak diizinkan masuk ke dalam ruang kegiatan.'],
      ['Apakah PUPA Center menyediakan penempatan kerja atau magang?', 'Magang kerja adalah bagian dari rangkaian program PUPA (Karya). PUPA Center menyediakan program pengenalan dunia kerja dan pengalaman praktik, namun bukan sebagai jaminan penempatan kerja.'],
      ['Bagaimana komunikasi dengan orang tua berlangsung?', 'Komunikasi dilakukan sesuai keperluan melalui aplikasi yang tersedia. Laporan perkembangan/evaluasi hasil pendampingan diberikan secara berkala dan terstruktur, serta tersedia diskusi dengan tim PUPA Center bila diperlukan.'],
      ['Apakah ada kegiatan di luar PUPA Center?', 'Ya. PUPA mendorong peserta aktif dan mandiri berkegiatan di area publik. Outing, hangout, dan berbelanja adalah hal rutin yang dikembangkan dalam program kegiatan PUPA secara terstruktur, selaras dengan program.'],
      ['Bagaimana cara mendaftar?', 'Pendaftaran dapat dilakukan dengan menghubungi admin PUPA Center untuk mendapatkan informasi detail.'],
      ['Bagaimana jadwal kegiatan di PUPA Center?', 'Kegiatan dilaksanakan lima hari dalam seminggu (Senin–Jumat). Peserta PUPA Mandiri berkegiatan pukul 09.00–15.00 WIB, dan peserta PUPA Karya pukul 09.00–14.30 WIB.'],
      ['Apakah peserta akan mendapat pekerjaan setelah menyelesaikan program?', 'PUPA Center tidak menjamin penempatan kerja. Namun, program PUPA Center dirancang untuk membekali peserta dengan keterampilan kerja, kebiasaan kerja, dan pengalaman praktik yang relevan sebagai persiapan menuju dunia kerja atau aktivitas produktif lainnya.'],
      ['Anak saya non-verbal. Apakah bisa mengikuti program?', 'PUPA Center terbuka untuk individu dengan berbagai profil kebutuhan. Kesesuaian program bagi keseluruhan peserta (verbal dan/atau non-verbal) akan ditentukan melalui proses asesmen awal guna melihat kebutuhan, kemampuan, serta bentuk pendampingan yang diperlukan.'],
      ['Bagaimana struktur kelas, mengingat keberagaman spektrum autisme?', 'PUPA Center menerapkan masa probation selama 1–3 bulan. Pada periode ini, tim melakukan asesmen dan observasi untuk memahami profil, kebutuhan, serta pace berkegiatan peserta. Peserta akan bergabung pada kelompok yang selaras dengan kebutuhannya.'],
      ['Apakah pendaftaran dapat dilakukan kapan saja?', 'Ya, pendaftaran dibuka sepanjang tahun. PUPA Center membagi programnya menjadi tiga term setiap tahun. Peserta yang bergabung antara Januari–Juni dapat masuk ke program yang sedang berjalan, dengan materi yang terlewat disesuaikan melalui Individualized Education Plan (IEP). Peserta yang bergabung antara Juli–Desember akan mengulang paket program pada tahun berikutnya, karena lebih dari 50% materi program telah selesai.'],
    ],
  },
};
const c = content[lang];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: c.faq.map(([q, a]) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---
<Layout lang={lang} routeKey="enrollment" title={c.metaTitle} description={c.metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
      <p class="lede">{c.intro}</p>
    </div>
  </section>

  <section class="steps">
    <div class="wrap">
      <h2 class="steps-title">{c.stepsTitle}</h2>
      <div class="steps-grid">
        <div class="timeline">
          {c.steps.map((s, i) => (
            <details class="tl-step" open={i === 0}>
              <summary>
                <span class="tl-node" aria-hidden="true">{i + 1}</span>
                <span class="tl-title">{s[0]}</span>
                <span class="faq-icon" aria-hidden="true"></span>
              </summary>
              <div class="tl-body"><p>{s[1]}</p></div>
            </details>
          ))}
          <a class="btn btn-primary steps-cta" href={wa} rel="noopener">{c.ctaStart}</a>
        </div>
        <div class="steps-photo">
          <img src="/images/a6701624.jpg" alt="A participant taking part in an activity at PUPA Center" loading="lazy" width="520" height="680" />
        </div>
      </div>
    </div>
  </section>

  <section class="faq" id="faq">
    <div class="wrap faq-grid">
      <div class="faq-head">
        <h2><span class="faq-title-hl">{c.faqTitle}</span></h2>
      </div>
      <div class="faq-list">
        {c.faq.map((f) => (
          <details>
            <summary><span>{f[0]}</span><span class="faq-icon" aria-hidden="true"></span></summary>
            <p>{f[1]}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid var(--line)}
.page-head .lede{font-size:1.15rem;color:var(--ink-soft);margin-top:18px}
.steps{padding:64px 0}
.steps-title{margin-bottom:32px}
.steps-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:56px;align-items:start}
.timeline{position:relative}
.timeline::before{content:"";position:absolute;left:21px;top:14px;bottom:70px;width:2px;background:var(--teal-100);z-index:0}
.tl-step{position:relative;border-bottom:1px solid rgba(15,107,102,.16)}
.tl-step:first-child{border-top:1px solid rgba(15,107,102,.16)}
.tl-step summary{cursor:pointer;list-style:none;display:flex;align-items:center;gap:16px;padding:16px 40px 16px 0;min-height:44px;position:relative}
.tl-step summary::-webkit-details-marker{display:none}
.tl-node{flex:none;position:relative;z-index:1;display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;background:var(--teal-700);color:#fff;font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:1.05rem;box-shadow:0 0 0 4px var(--bg)}
.tl-step[open] .tl-node{background:var(--orange-500);color:#2B1503}
.tl-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:600;font-size:1.12rem;color:var(--teal-700)}
.tl-step summary .faq-icon{right:2px}
.tl-body{padding:0 0 18px 60px}
.tl-body p{color:var(--ink-soft)}
.steps-cta{margin-top:26px;margin-left:0}
.steps-photo{position:sticky;top:100px}
.steps-photo img{width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:var(--radius-lg);box-shadow:0 16px 40px rgba(11,68,65,.16)}
@media (max-width:960px){.steps-grid{grid-template-columns:1fr;gap:32px}.steps-photo{position:static;order:-1}.faq-grid{grid-template-columns:1fr;gap:24px}.faq-head{position:static}}
.faq{background:linear-gradient(110deg,var(--sage),var(--peach));border-top:1px solid #EFE4D2;padding:72px 0}
.faq-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:56px;align-items:start}
.faq-head{position:sticky;top:100px}
.faq-title-hl{display:inline;background:var(--orange-500);color:#fff;padding:4px 14px;box-decoration-break:clone;-webkit-box-decoration-break:clone;line-height:1.6}
.faq-head h2::after{display:none}
.faq-list{display:grid}
details{border-bottom:1px solid rgba(15,107,102,.28)}
details:first-child{border-top:1px solid rgba(15,107,102,.28)}
summary{cursor:pointer;font-weight:600;color:var(--teal-700);padding:18px 40px 18px 2px;min-height:44px;position:relative;list-style:none;display:block}
summary::-webkit-details-marker{display:none}
summary:hover{color:var(--teal-900)}
.faq-icon{position:absolute;right:4px;top:50%;width:18px;height:18px;transform:translateY(-50%)}
.faq-icon::before,.faq-icon::after{content:"";position:absolute;background:var(--teal-700);border-radius:2px}
.faq-icon::before{left:0;top:8px;width:18px;height:2px}
.faq-icon::after{left:8px;top:0;width:2px;height:18px;transition:opacity .15s ease}
details[open] .faq-icon::after{opacity:0}
details p{padding:0 40px 20px 2px;color:var(--teal-900);opacity:.85}
</style>
