---
import { type Lang } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;

const t = {
  en: {
    open: 'Accessibility options',
    title: 'Accessibility',
    textSize: 'Text size',
    decrease: 'Decrease text size',
    increase: 'Increase text size',
    contrast: 'High contrast',
    spacing: 'Readable spacing',
    links: 'Highlight links',
    readAloud: 'Read page aloud',
    stop: 'Stop reading',
    reset: 'Reset all',
    on: 'On', off: 'Off',
    more: 'Full accessibility guide',
    close: 'Close',
  },
  id: {
    open: 'Opsi aksesibilitas',
    title: 'Aksesibilitas',
    textSize: 'Ukuran teks',
    decrease: 'Perkecil ukuran teks',
    increase: 'Perbesar ukuran teks',
    contrast: 'Kontras tinggi',
    spacing: 'Spasi mudah dibaca',
    links: 'Sorot tautan',
    readAloud: 'Bacakan halaman',
    stop: 'Hentikan',
    reset: 'Atur ulang',
    on: 'Aktif', off: 'Nonaktif',
    more: 'Panduan aksesibilitas lengkap',
    close: 'Tutup',
  },
}[lang];

const guideHref = lang === 'id' ? '/id/aksesibilitas/' : '/accessibility/';
const readLang = lang === 'id' ? 'id-ID' : 'en-US';
---
<button id="a11y-toggle" class="a11y-toggle" aria-label={t.open} aria-expanded="false" aria-controls="a11y-panel" type="button">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="4" r="1.6" fill="currentColor" stroke="none"/>
    <path d="M4 8h16"/><path d="M12 8v7"/><path d="M9 21l3-6 3 6"/>
  </svg>
</button>

<div id="a11y-panel" class="a11y-panel" role="dialog" aria-modal="false" aria-label={t.title} hidden>
  <div class="a11y-head">
    <h2>{t.title}</h2>
    <button id="a11y-close" class="a11y-close" aria-label={t.close} type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="a11y-row">
    <span class="a11y-label">{t.textSize}</span>
    <div class="a11y-stepper">
      <button data-a11y="text-dec" aria-label={t.decrease} type="button">A−</button>
      <span id="a11y-text-val" aria-live="polite">100%</span>
      <button data-a11y="text-inc" aria-label={t.increase} type="button">A+</button>
    </div>
  </div>

  <button class="a11y-switch" data-a11y="contrast" aria-pressed="false" type="button">
    <span>{t.contrast}</span><span class="a11y-state" data-on={t.on} data-off={t.off}>{t.off}</span>
  </button>
  <button class="a11y-switch" data-a11y="spacing" aria-pressed="false" type="button">
    <span>{t.spacing}</span><span class="a11y-state" data-on={t.on} data-off={t.off}>{t.off}</span>
  </button>
  <button class="a11y-switch" data-a11y="links" aria-pressed="false" type="button">
    <span>{t.links}</span><span class="a11y-state" data-on={t.on} data-off={t.off}>{t.off}</span>
  </button>

  <button class="a11y-read" data-a11y="read" data-lang={readLang} data-stop={t.stop} type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/></svg>
    <span data-read-label>{t.readAloud}</span>
  </button>

  <div class="a11y-foot">
    <button class="a11y-reset" data-a11y="reset" type="button">{t.reset}</button>
    <a class="a11y-more" href={guideHref}>{t.more} →</a>
  </div>
</div>

<style>
.a11y-toggle{
  position:fixed;right:20px;bottom:20px;z-index:90;
  width:56px;height:56px;border-radius:50%;border:none;cursor:pointer;
  background:var(--teal-700);color:#fff;box-shadow:0 6px 20px rgba(11,68,65,.32);
  display:flex;align-items:center;justify-content:center;transition:background .2s ease,transform .2s ease;
}
.a11y-toggle:hover{background:var(--teal-900);transform:translateY(-2px)}
.a11y-toggle svg{width:28px;height:28px}

.a11y-panel{
  position:fixed;right:20px;bottom:88px;z-index:91;width:320px;max-width:calc(100vw - 40px);
  background:var(--surface);border:1px solid var(--line);border-radius:18px;
  box-shadow:0 16px 48px rgba(11,68,65,.24);padding:20px;
}
.a11y-panel[hidden]{display:none}
.a11y-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.a11y-head h2{font-size:1.2rem;margin:0}
.a11y-head h2::after{display:none}
.a11y-close{background:none;border:none;cursor:pointer;color:var(--ink-soft);padding:6px;border-radius:8px}
.a11y-close:hover{background:var(--teal-050)}
.a11y-close svg{width:20px;height:20px}

.a11y-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.a11y-label{font-weight:600}
.a11y-stepper{display:flex;align-items:center;gap:4px}
.a11y-stepper button{min-width:44px;min-height:44px;border:1px solid var(--line);background:var(--bg);border-radius:10px;cursor:pointer;font-weight:700;font-size:1rem;color:var(--teal-700)}
.a11y-stepper button:hover{background:var(--teal-050)}
.a11y-stepper span{min-width:52px;text-align:center;font-weight:600;font-size:.95rem}

.a11y-switch{
  width:100%;display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;margin-bottom:10px;border:1px solid var(--line);background:var(--bg);
  border-radius:12px;cursor:pointer;font-weight:600;font-size:1rem;color:var(--ink);min-height:44px;
}
.a11y-switch:hover{background:var(--teal-050)}
.a11y-switch[aria-pressed="true"]{background:var(--teal-700);color:#fff;border-color:var(--teal-700)}
.a11y-state{font-size:.85rem;font-weight:700;opacity:.85}

.a11y-read{
  width:100%;display:flex;align-items:center;justify-content:center;gap:10px;
  padding:14px 16px;margin:6px 0 16px;border:2px solid var(--orange-500);background:var(--orange-500);
  border-radius:999px;cursor:pointer;font-weight:600;font-size:1rem;color:#2B1503;min-height:48px;
}
.a11y-read:hover{background:var(--orange-700);border-color:var(--orange-700);color:#fff}
.a11y-read.reading{background:var(--teal-900);border-color:var(--teal-900);color:#fff}
.a11y-read svg{width:20px;height:20px}

.a11y-foot{display:flex;align-items:center;justify-content:space-between;gap:12px;border-top:1px solid var(--line);padding-top:14px}
.a11y-reset{background:none;border:none;cursor:pointer;color:var(--ink-soft);font-weight:600;text-decoration:underline;padding:6px 0}
.a11y-reset:hover{color:var(--ink)}
.a11y-more{font-weight:600;text-decoration:none;font-size:.95rem}
.a11y-more:hover{text-decoration:underline}

@media (max-width:560px){
  .a11y-toggle{right:16px;bottom:16px}
  .a11y-panel{right:16px;left:16px;bottom:84px;width:auto}
}

/* ---- Applied accessibility states (on <html>) ---- */
html[data-a11y-contrast="on"]{--ink:#000;--ink-soft:#1a1a1a;--bg:#fff;--surface:#fff;--line:#000;--cream:#fff;--peach:#fff;--sage:#fff}
html[data-a11y-contrast="on"] .btn-primary,
html[data-a11y-contrast="on"] .btn-donate{background:#000;color:#fff;border-color:#000}
html[data-a11y-contrast="on"] a{text-decoration:underline}
html[data-a11y-spacing="on"] body{line-height:2 !important;letter-spacing:.04em;word-spacing:.1em}
html[data-a11y-spacing="on"] p,html[data-a11y-spacing="on"] li{margin-bottom:1.2em}
html[data-a11y-links="on"] a:not(.btn):not(.a11y-toggle):not(.a11y-read){
  background:#ffec99;color:#1a1a1a !important;text-decoration:underline;box-shadow:0 0 0 2px #ffec99;
}
.a11y-read-highlight{background:#ffe08a;box-shadow:0 0 0 3px #ffe08a;border-radius:3px}
</style>

<script>
  (function () {
    const html = document.documentElement;
    const KEY = 'pupa-a11y';
    const state = { text: 100, contrast: false, spacing: false, links: false };

    // restore saved prefs
    try {
      const saved = JSON.parse(localStorage.getItem(KEY) || '{}');
      Object.assign(state, saved);
    } catch (e) {}

    function apply() {
      html.style.fontSize = state.text === 100 ? '' : state.text + '%';
      const val = document.getElementById('a11y-text-val');
      if (val) val.textContent = state.text + '%';
      html.setAttribute('data-a11y-contrast', state.contrast ? 'on' : 'off');
      html.setAttribute('data-a11y-spacing', state.spacing ? 'on' : 'off');
      html.setAttribute('data-a11y-links', state.links ? 'on' : 'off');
      document.querySelectorAll('[data-a11y="contrast"],[data-a11y="spacing"],[data-a11y="links"]').forEach((btn) => {
        const key = btn.getAttribute('data-a11y');
        const isOn = state[key];
        btn.setAttribute('aria-pressed', String(isOn));
        const stateEl = btn.querySelector('.a11y-state');
        if (stateEl) stateEl.textContent = isOn ? (stateEl.dataset.on || 'On') : (stateEl.dataset.off || 'Off');
      });
      try { localStorage.setItem(KEY, JSON.stringify(state)); } catch (e) {}
    }

    const panel = document.getElementById('a11y-panel');
    const toggle = document.getElementById('a11y-toggle');
    const closeBtn = document.getElementById('a11y-close');

    function openPanel() { panel.hidden = false; toggle.setAttribute('aria-expanded', 'true'); }
    function closePanel() { panel.hidden = true; toggle.setAttribute('aria-expanded', 'false'); toggle.focus(); }

    toggle.addEventListener('click', () => (panel.hidden ? openPanel() : closePanel()));
    closeBtn.addEventListener('click', closePanel);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !panel.hidden) closePanel(); });

    document.querySelectorAll('[data-a11y]').forEach((btn) => {
      const action = btn.getAttribute('data-a11y');
      if (action === 'read' || action === 'reset') return;
      btn.addEventListener('click', () => {
        if (action === 'text-inc') state.text = Math.min(160, state.text + 10);
        else if (action === 'text-dec') state.text = Math.max(80, state.text - 10);
        else state[action] = !state[action];
        apply();
      });
    });

    // Reset
    document.querySelector('[data-a11y="reset"]').addEventListener('click', () => {
      state.text = 100; state.contrast = false; state.spacing = false; state.links = false;
      apply();
      stopReading();
    });

    // ---- Read aloud (Web Speech API) ----
    const readBtn = document.querySelector('[data-a11y="read"]');
    const readLabel = readBtn.querySelector('[data-read-label]');
    const readLangCode = readBtn.getAttribute('data-lang') || 'en-US';
    const labels = { read: readLabel.textContent, stop: readBtn.getAttribute('data-stop') || 'Stop' };
    let reading = false;

    function getReadable() {
      const main = document.querySelector('main') || document.body;
      // collect visible text from headings and paragraphs
      const nodes = main.querySelectorAll('h1,h2,h3,h4,p,li');
      const out = [];
      nodes.forEach((n) => {
        if (n.closest('.a11y-panel')) return;
        const txt = (n.textContent || '').trim();
        if (txt.length > 1) out.push(txt);
      });
      return out.join('. ');
    }

    function stopReading() {
      if (window.speechSynthesis) window.speechSynthesis.cancel();
      reading = false;
      readBtn.classList.remove('reading');
      readLabel.textContent = labels.read;
    }

    readBtn.addEventListener('click', () => {
      if (!('speechSynthesis' in window)) {
        alert('Sorry, your browser does not support read-aloud.');
        return;
      }
      if (reading) { stopReading(); return; }
      const text = getReadable();
      if (!text) return;
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = readLangCode;
      utter.rate = 0.95;
      utter.onend = stopReading;
      utter.onerror = stopReading;
      window.speechSynthesis.cancel();
      window.speechSynthesis.speak(utter);
      reading = true;
      readBtn.classList.add('reading');
      readLabel.textContent = labels.stop;
    });

    window.addEventListener('beforeunload', stopReading);
    apply();
  })();
</script>
