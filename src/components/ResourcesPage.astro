---
import Layout from '../layouts/Layout.astro';
import { routes, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = (key: string) => (routes[key] ?? routes.home)[lang];

const content = {
  en: {
    metaTitle: 'Resources — News, Parent Resources & Stories | PUPA Center',
    metaDescription: 'Stay connected with PUPA Center: join our WhatsApp community for news and updates, read practical articles for parents, and follow our participants\u2019 growth journeys.',
    h1: 'Resources',
    newsTitle: 'News & updates',
    newsBody: 'We welcome anyone who would like to stay connected to join our PUPA Center WhatsApp community. It\u2019s an accessible space to stay informed and engaged with our work as it unfolds, allowing you to be part of the ongoing journey we are building together.',
    expectTitle: 'What to expect',
    expect: [
      ['Program updates', 'Be the first to know about new curriculum developments and intake schedules for Mandiri, Karya, and Access.'],
      ['Upcoming events', 'Stay informed about PUPA Center\u2019s activities, community workshops, and public outings as they are announced.'],
      ['Milestones & moments', 'Celebrate participant achievements and community highlights as they happen.'],
      ['A shared space', 'A dedicated channel for families, supporters, and participants to remain united in our vision for the future.'],
    ],
    newsCta: 'Join the WhatsApp community',
    qrAlt: 'QR code to join the PUPA Community WhatsApp group',
    qrCaption: 'Or scan with your phone',
    parentsTitle: 'Resources for parents',
    parentsBody: 'Practical articles for families of neurodivergent young adults — independence, routines, life skills, executive function, and the transition to adulthood.',
    parentsCta: 'Read the articles',
    storiesTitle: 'Growth journeys',
    storiesBody: 'Real stories of PUPA Center participants — journeys of courage, capability, and progress toward independence and meaningful work.',
    storiesCta: 'Read the stories',
    impactTitle: 'Impact & annual reports',
    impactBody: 'Our annual report and impact figures are being prepared for the new website.',
    impactFlag: 'Content pending from PUPA team',
  },
  id: {
    metaTitle: 'Sumber Daya — Berita, Sumber Daya Orang Tua & Kisah | PUPA Center',
    metaDescription: 'Tetap terhubung dengan PUPA Center: bergabunglah dengan komunitas WhatsApp kami untuk berita dan kabar terbaru, baca artikel praktis untuk orang tua, dan ikuti kisah pertumbuhan para peserta.',
    h1: 'Sumber daya',
    newsTitle: 'Berita & kabar terbaru',
    newsBody: 'Kami menyambut siapa pun yang ingin tetap terhubung untuk bergabung dengan komunitas WhatsApp PUPA Center. Ini adalah ruang yang mudah diakses untuk tetap mendapat informasi dan terlibat dengan kerja kami, sehingga Anda menjadi bagian dari perjalanan yang kami bangun bersama.',
    expectTitle: 'Apa yang bisa diharapkan',
    expect: [
      ['Kabar program', 'Jadilah yang pertama mengetahui perkembangan kurikulum baru dan jadwal penerimaan Mandiri, Karya, dan Access.'],
      ['Acara mendatang', 'Dapatkan informasi tentang kegiatan PUPA Center, lokakarya komunitas, dan kegiatan luar saat diumumkan.'],
      ['Pencapaian & momen', 'Rayakan pencapaian peserta dan momen komunitas saat terjadi.'],
      ['Ruang bersama', 'Saluran khusus bagi keluarga, pendukung, dan peserta untuk tetap bersatu dalam visi kita bersama.'],
    ],
    newsCta: 'Gabung komunitas WhatsApp',
    qrAlt: 'Kode QR untuk bergabung dengan grup WhatsApp PUPA Community',
    qrCaption: 'Atau pindai dengan ponsel Anda',
    parentsTitle: 'Sumber daya untuk orang tua',
    parentsBody: 'Artikel praktis untuk keluarga anak muda neurodivergen — kemandirian, rutinitas, kecakapan hidup, fungsi eksekutif, dan transisi menuju kedewasaan. Saat ini tersedia dalam bahasa Inggris.',
    parentsCta: 'Baca artikelnya',
    storiesTitle: 'Kisah pertumbuhan',
    storiesBody: 'Kisah nyata peserta PUPA Center — perjalanan keberanian, kemampuan, dan kemajuan menuju kemandirian serta pekerjaan yang bermakna.',
    storiesCta: 'Baca kisahnya',
    impactTitle: 'Dampak & laporan tahunan',
    impactBody: 'Laporan tahunan dan angka dampak kami sedang disiapkan untuk situs baru.',
    impactFlag: 'Menunggu konten dari tim PUPA',
  },
};
const c = content[lang];
---
<Layout lang={lang} routeKey="resources" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap"><h1>{c.h1}</h1></div>
  </section>

  <section class="res-sec" id="news">
    <div class="wrap">
      <h2>{c.newsTitle}</h2>
      <p class="res-body">{c.newsBody}</p>
      <h3>{c.expectTitle}</h3>
      <div class="card-grid expect-grid">
        {c.expect.map((e) => (
          <div class="card"><h4>{e[0]}</h4><p>{e[1]}</p></div>
        ))}
      </div>
      <div class="join-row">
        <a class="btn btn-primary" href="https://chat.whatsapp.com/GY7IwyE2UXS5DoBup80S81" rel="noopener">{c.newsCta}</a>
        <figure class="qr-box">
          <img src="/images/brand/wa-community-qr.png" alt={c.qrAlt} width="180" height="180" loading="lazy" />
          <figcaption>{c.qrCaption}</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="res-sec alt" id="parents">
    <div class="wrap">
      <h2>{c.parentsTitle}</h2>
      <p class="res-body">{c.parentsBody}</p>
      <a class="btn btn-secondary" href={p('blog')}>{c.parentsCta}</a>
    </div>
  </section>

  <section class="res-sec" id="stories">
    <div class="wrap">
      <h2>{c.storiesTitle}</h2>
      <p class="res-body">{c.storiesBody}</p>
      <a class="btn btn-secondary" href={p('stories')}>{c.storiesCta}</a>
    </div>
  </section>

  <section class="res-sec alt" id="impact">
    <div class="wrap">
      <h2>{c.impactTitle}</h2>
      <p class="res-body">{c.impactBody}</p>
      <span class="placeholder-flag">{c.impactFlag}</span>
    </div>
  </section>
</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid var(--line)}
.res-sec{padding:56px 0}
.res-sec.alt{background:var(--surface);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.res-body{color:var(--ink-soft);margin:14px 0 22px}
.res-sec h3{margin:8px 0 6px}
.expect-grid{grid-template-columns:repeat(4,1fr);margin-bottom:26px}
.expect-grid h4{font-family:'Bricolage Grotesque',sans-serif;font-size:1.05rem}
.res-sec .placeholder-flag{margin-top:16px}
.join-row{display:flex;align-items:center;gap:28px;flex-wrap:wrap}
.qr-box{margin:0;text-align:center}
.qr-box img{border:1px solid var(--line);border-radius:var(--radius);background:#fff}
.qr-box figcaption{font-size:.85rem;color:var(--ink-soft);margin-top:6px}
@media (max-width:960px){.expect-grid{grid-template-columns:1fr 1fr}}
</style>
