---
import Layout from '../layouts/Layout.astro';
import { routes, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = (key: string) => (routes[key] ?? routes.home)[lang];
const wa = 'https://wa.me/62818533698';

const c = {
  en: {
    metaTitle: 'Our Workshops — PUPA Center Business Units & Vocational Training',
    metaDescription: 'PUPA Center runs sheltered workplaces where neurodivergent young adults learn real work skills: PUPA Bites, PUPA Coffee, PUPA Tacta, and PUPA X Eggstra.',
    h1: 'Our workshops',
    lede: 'PUPA runs its own small business units as sheltered workplaces. Here, participants don\u2019t just make products — they practice the full rhythm of real work: preparing, producing, packaging, handling orders, and completing payments. Each unit is a safe, structured environment to build focus, responsibility, and the confidence to work.',
    howTitle: 'How the workshops work',
    howBody: 'Every workshop mirrors a real job. Participants are supported step by step through the whole cycle — from preparation and production to packaging, fulfilling orders, and handling payment — learning to stay focused on a task, follow a process, work alongside others, and take pride in a finished result. It is where the skills built in Mandiri and Karya are put to work, and a bridge toward the supported employment of Access.',
    unitsTitle: 'Our business units',
    units: [
      {
        name: 'PUPA Bites',
        tag: 'Baking & order fulfillment',
        desc: 'Participants bake cookies for hampers and pre-orders — learning recipe preparation, careful baking, quality checks, packaging, and fulfilling customer orders on time.',
        skills: ['Preparation & baking', 'Packaging', 'Order fulfillment'],
      },
      {
        name: 'PUPA Coffee',
        tag: 'Barista & customer service',
        desc: 'Our to-go coffee shop serves the nearby community. Participants learn to make coffee, serve customers, and handle payments — building real barista and customer-service skills in a live setting.',
        skills: ['Coffee making', 'Customer service', 'Handling payments'],
      },
      {
        name: 'PUPA Tacta',
        tag: 'Making sensory tools',
        desc: 'Participants produce 3D-printed fidgets and sensory tools — useful for neurodivergent people and others. They learn production, finishing, quality control, and packaging for sale.',
        skills: ['Production', 'Quality control', 'Packaging'],
      },
      {
        name: 'PUPA X Eggstra',
        tag: 'Cleaning, packing & fulfillment',
        desc: 'Participants clean and pack eggs into containers to fulfill orders, currently supported mainly by our community. They practice careful handling, consistent packing, and completing orders reliably.',
        skills: ['Careful handling', 'Packing', 'Order fulfillment'],
      },
    ],
    supportTitle: 'Support the workshops',
    supportBody: 'Ordering from our units, or partnering with them, gives participants real customers to serve and real orders to fulfill — the most meaningful practice there is. If you would like to order or collaborate, we would love to hear from you.',
    supportCta: 'Message us on WhatsApp',
  },
  id: {
    metaTitle: 'Workshop Kami — Unit Usaha & Pelatihan Vokasional PUPA Center',
    metaDescription: 'PUPA Center menjalankan sheltered workplace tempat individu neurodivergen belajar keterampilan kerja nyata: PUPA Bites, PUPA Coffee, PUPA Tacta, dan PUPA X Eggstra.',
    h1: 'Workshop kami',
    lede: 'PUPA menjalankan unit-unit usaha kecil sebagai sheltered workplace. Di sini, peserta tidak hanya membuat produk — mereka melatih ritme kerja yang sesungguhnya: menyiapkan, memproduksi, mengemas, menangani pesanan, dan menyelesaikan pembayaran. Setiap unit adalah lingkungan yang aman dan terstruktur untuk membangun fokus, tanggung jawab, dan kepercayaan diri untuk bekerja.',
    howTitle: 'Bagaimana workshop berjalan',
    howBody: 'Setiap workshop mencerminkan pekerjaan nyata. Peserta didampingi langkah demi langkah melalui seluruh siklus — dari persiapan dan produksi hingga pengemasan, pemenuhan pesanan, dan penanganan pembayaran — belajar untuk tetap fokus pada tugas, mengikuti proses, bekerja bersama orang lain, dan bangga atas hasil yang selesai. Di sinilah keterampilan yang dibangun dalam Mandiri dan Karya dipraktikkan, sekaligus menjadi jembatan menuju pekerjaan dengan pendampingan pada program Access.',
    unitsTitle: 'Unit usaha kami',
    units: [
      {
        name: 'PUPA Bites',
        tag: 'Membuat kue & pemenuhan pesanan',
        desc: 'Peserta membuat kue kering untuk hampers dan pre-order — belajar menyiapkan resep, memanggang dengan cermat, memeriksa kualitas, mengemas, dan memenuhi pesanan pelanggan tepat waktu.',
        skills: ['Persiapan & memanggang', 'Pengemasan', 'Pemenuhan pesanan'],
      },
      {
        name: 'PUPA Coffee',
        tag: 'Barista & layanan pelanggan',
        desc: 'Kedai kopi to-go kami melayani komunitas sekitar. Peserta belajar membuat kopi, melayani pelanggan, dan menangani pembayaran — membangun keterampilan barista dan layanan pelanggan yang nyata.',
        skills: ['Membuat kopi', 'Layanan pelanggan', 'Menangani pembayaran'],
      },
      {
        name: 'PUPA Tacta',
        tag: 'Membuat alat sensorik',
        desc: 'Peserta memproduksi fidget dan alat sensorik cetak 3D — bermanfaat bagi individu neurodivergen dan lainnya. Mereka belajar produksi, penyelesaian akhir, kontrol kualitas, dan pengemasan untuk dijual.',
        skills: ['Produksi', 'Kontrol kualitas', 'Pengemasan'],
      },
      {
        name: 'PUPA X Eggstra',
        tag: 'Membersihkan, mengemas & memenuhi pesanan',
        desc: 'Peserta membersihkan dan mengemas telur ke dalam wadah untuk memenuhi pesanan, saat ini terutama didukung oleh komunitas kami. Mereka melatih penanganan yang cermat, pengemasan yang konsisten, dan penyelesaian pesanan yang andal.',
        skills: ['Penanganan cermat', 'Pengemasan', 'Pemenuhan pesanan'],
      },
    ],
    supportTitle: 'Dukung workshop kami',
    supportBody: 'Memesan dari unit kami, atau bermitra dengan mereka, memberi peserta pelanggan nyata untuk dilayani dan pesanan nyata untuk dipenuhi — latihan yang paling bermakna. Jika Anda ingin memesan atau berkolaborasi, kami dengan senang hati mendengarnya.',
    supportCta: 'Hubungi kami via WhatsApp',
  },
}[lang];

// Placeholder images — swap in real photos when provided
const unitImgs = ['/images/workshop-bites.jpg', '/images/workshop-coffee.jpg', '/images/workshop-tacta.jpg', '/images/workshop-eggstra.jpg'];
const unitIcons = [
  // Bites — cookie
  '<circle cx="12" cy="12" r="9"/><circle cx="9" cy="10" r="1" fill="currentColor"/><circle cx="14" cy="9" r="1" fill="currentColor"/><circle cx="15" cy="14" r="1" fill="currentColor"/><circle cx="10" cy="15" r="1" fill="currentColor"/>',
  // Coffee — cup
  '<path d="M4 8h13v5a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4z"/><path d="M17 9h2a2 2 0 0 1 0 4h-2"/><path d="M7 4v1M10 3v2M13 4v1"/>',
  // Tacta — puzzle/fidget
  '<path d="M4 7h5V5a2 2 0 0 1 4 0v2h5v5h2a2 2 0 0 1 0 4h-2v3H4v-5H2a2 2 0 0 1 0-4h2z"/>',
  // Eggstra — egg
  '<path d="M12 3c-4 0-7 6-7 10a7 7 0 0 0 14 0c0-4-3-10-7-10z"/>',
];
---
<Layout lang={lang} routeKey="workshops" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
    </div>
  </section>

  <section class="how-sec">
    <div class="wrap">
      <h2>{c.howTitle}</h2>
      <p class="how-body">{c.howBody}</p>
    </div>
  </section>

  <section class="units-sec">
    <div class="wrap">
      <h2>{c.unitsTitle}</h2>
      <div class="units-grid">
        {c.units.map((u, i) => (
          <article class="unit-card">
            <div class="unit-photo">
              <img src={unitImgs[i]} alt="" loading="lazy" width="480" height="320"
                   onerror="this.style.display='none';this.parentElement.classList.add('no-photo')" />
              <span class="unit-photo-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={unitIcons[i]}></svg>
              </span>
            </div>
            <div class="unit-body">
              <span class="unit-tag">{u.tag}</span>
              <h3>{u.name}</h3>
              <p>{u.desc}</p>
              <ul class="unit-skills">
                {u.skills.map((sk) => <li>{sk}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="support-sec">
    <div class="wrap support-inner">
      <h2>{c.supportTitle}</h2>
      <p>{c.supportBody}</p>
      <a class="btn btn-primary" href={wa} rel="noopener">{c.supportCta}</a>
    </div>
  </section>
</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid #EFE4D2}
.page-head .lede{font-size:1.15rem;color:var(--ink-soft);margin-top:18px;max-width:66ch}

.how-sec{padding:56px 0 8px}
.how-body{max-width:70ch;color:var(--ink-soft)}

.units-sec{padding:48px 0 64px}
.units-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px;margin-top:24px}
.unit-card{display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--line);border-radius:var(--radius-lg);overflow:hidden;transition:transform .2s ease,box-shadow .2s ease}
.unit-card:hover{transform:translateY(-3px);box-shadow:0 14px 32px rgba(11,68,65,.1)}
.unit-photo{position:relative;background:linear-gradient(150deg,var(--sage),var(--peach));aspect-ratio:16/9}
.unit-photo img{width:100%;height:100%;object-fit:cover}
.unit-photo-icon{position:absolute;left:18px;bottom:-24px;width:52px;height:52px;border-radius:14px;background:#fff;border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--teal-700);box-shadow:0 6px 16px rgba(11,68,65,.12)}
.unit-photo.no-photo{display:flex;align-items:center;justify-content:center}
.unit-photo.no-photo .unit-photo-icon{position:static;width:64px;height:64px}
.unit-photo-icon svg{width:28px;height:28px}
.unit-body{padding:34px 26px 26px;display:flex;flex-direction:column;flex-grow:1}
.unit-tag{font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--orange-700)}
.unit-body h3{font-size:1.4rem;margin:6px 0 10px}
.unit-body p{color:var(--ink-soft);margin-bottom:16px;flex-grow:1}
.unit-skills{list-style:none;display:flex;flex-wrap:wrap;gap:8px;padding:0;margin-top:auto}
.unit-skills li{font-size:.82rem;font-weight:600;color:var(--teal-900);background:var(--teal-050);border:1px solid var(--teal-100);padding:5px 12px;border-radius:999px}

.support-sec{padding:0 0 72px}
.support-inner{background:var(--teal-900);color:#fff;border-radius:var(--radius-lg);padding:52px 48px;text-align:center}
.support-inner h2{color:#fff}
.support-inner p{color:#C8DEDC;max-width:56ch;margin:14px auto 26px}

@media (max-width:820px){
  .units-grid{grid-template-columns:1fr}
}
</style>
