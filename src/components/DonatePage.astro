---
import Layout from '../layouts/Layout.astro';
import { type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const content = {
  en: {
    metaTitle: 'Donate — Support Neurodivergent Young Adults | PUPA Center',
    metaDescription: 'Donate to PUPA Center in Tangerang, Indonesia. Your gift funds program scholarships, training materials, and job coaching for neurodivergent young adults.',
    h1: 'Donate',
    intro: 'Donations fund program scholarships, training materials, and job coaching for neurodivergent young adults. Every contribution goes directly to participant support, and we publish how funds are used.',
    what: [
      ['Scholarships', 'Help a family afford a place in the Mandiri, Karya, or Access program.'],
      ['Training materials', 'Fund the tools, kitchen supplies, and vocational equipment participants learn with every day.'],
      ['Job coaching', 'Support coaching that helps participants succeed in internships and the workplace.'],
    ],
    waysTitle: 'Ways to give',
    bank: 'Bank transfer',
    bankDetail: 'Account name, bank, and account number will be listed here.',
    qris: 'QRIS',
    qrisDetail: 'Scan-to-give QRIS code will be displayed here.',
    corp: 'Corporate giving & CSR',
    corpDetail: 'Email info@pupacenter.org to discuss partnership and CSR programs.',
    flag: 'Payment details pending from PUPA team',
    confirm: 'After donating, you are welcome to confirm your gift via WhatsApp so we can thank you and share how it is used.',
    confirmCta: 'Confirm a donation on WhatsApp',
  },
  id: {
    metaTitle: 'Donasi — Dukung Anak Muda Neurodivergen | PUPA Center',
    metaDescription: 'Berdonasi untuk PUPA Center di Tangerang, Indonesia. Donasi Anda mendanai beasiswa program, materi pelatihan, dan pendampingan kerja bagi anak muda neurodivergen.',
    h1: 'Donasi',
    intro: 'Donasi mendanai beasiswa program, materi pelatihan, dan pendampingan kerja bagi anak muda neurodivergen. Setiap kontribusi langsung digunakan untuk mendukung peserta, dan kami mempublikasikan penggunaan dana.',
    what: [
      ['Beasiswa', 'Membantu keluarga menjangkau biaya program Mandiri, Karya, atau Access.'],
      ['Materi pelatihan', 'Mendanai peralatan, perlengkapan dapur, dan alat vokasional yang digunakan peserta setiap hari.'],
      ['Pendampingan kerja', 'Mendukung pendampingan yang membantu peserta berhasil dalam magang dan dunia kerja.'],
    ],
    waysTitle: 'Cara berdonasi',
    bank: 'Transfer bank',
    bankDetail: 'Nama rekening, bank, dan nomor rekening akan dicantumkan di sini.',
    qris: 'QRIS',
    qrisDetail: 'Kode QRIS untuk berdonasi akan ditampilkan di sini.',
    corp: 'Donasi perusahaan & CSR',
    corpDetail: 'Email info@pupacenter.org untuk membahas kemitraan dan program CSR.',
    flag: 'Detail pembayaran menunggu dari tim PUPA',
    confirm: 'Setelah berdonasi, Anda dipersilakan mengonfirmasi donasi melalui WhatsApp agar kami dapat berterima kasih dan membagikan penggunaannya.',
    confirmCta: 'Konfirmasi donasi via WhatsApp',
  },
};
const c = content[lang];
---
<Layout lang={lang} routeKey="donate" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
      <p class="lede">{c.intro}</p>
    </div>
  </section>

  <section class="donate-what">
    <div class="wrap card-grid">
      {c.what.map((w) => (
        <div class="card"><h2 class="small-h">{w[0]}</h2><p>{w[1]}</p></div>
      ))}
    </div>
  </section>

  <section class="donate-ways">
    <div class="wrap">
      <h2>{c.waysTitle}</h2>
      <div class="card-grid ways-grid">
        <div class="card"><h3>{c.bank}</h3><p>{c.bankDetail}</p><span class="placeholder-flag">{c.flag}</span></div>
        <div class="card"><h3>{c.qris}</h3><p>{c.qrisDetail}</p><span class="placeholder-flag">{c.flag}</span></div>
        <div class="card"><h3>{c.corp}</h3><p>{c.corpDetail}</p></div>
      </div>
      <p class="confirm">{c.confirm}</p>
      <a class="btn btn-donate" href="https://wa.me/62818533698" rel="noopener">{c.confirmCta}</a>
    </div>
  </section>
</Layout>

<style>
.page-head{background:linear-gradient(120deg,var(--orange-100),#FDF3E7);padding:64px 0 48px;border-bottom:1px solid #F2D9BE}
.page-head .lede{font-size:1.15rem;color:#5C4630;margin-top:18px}
.donate-what{padding:56px 0 24px}
.small-h{font-size:1.15rem}
.donate-ways{padding:40px 0 72px}
.ways-grid{margin-top:20px}
.confirm{color:var(--ink-soft);margin:26px 0 18px}
</style>
