---
import Layout from '../layouts/Layout.astro';
import { type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const content = {
  en: {
    metaTitle: 'About PUPA Center — Our Story, Mission & Values',
    metaDescription: 'PUPA Center is a development center for neurodivergent young adults in Tangerang, Indonesia. Learn about our story, our neuro-affirming approach, and the values that guide our work.',
    h1: 'About PUPA Center',
    storyTitle: 'Our Story',
    highlights: [
      ['16–25', 'Ages we support'],
      ['3', 'Core programs'],
      ['5 days', 'Every week, Mon–Fri'],
      ['Alam Sutera', 'Tangerang, Indonesia'],
    ],
    story: [
      'PUPA was founded from a simple yet profound concern shared by many families of neurodivergent young adults: what kind of future awaits our children when we are no longer there to guide them? For parents of individuals with autism and other neurodivergent conditions, this question goes beyond survival — it speaks to independence, dignity, and purpose.',
      'The name PUPA, derived from Latin, means cocoon. It reflects our belief that meaningful growth happens within a safe, structured, and nurturing environment — one that protects, strengthens, and prepares individuals without rushing or forcing transformation.',
      'PUPA began as a response to the concerns of families, in a landscape where structured resources, proven curricula, and inclusive pathways for neurodivergent young adults were limited. PUPA chose a different approach: designing programs that build habits, life skills, and work readiness in ways that respect each individual\u2019s abilities, pace, and personal standard of success.',
      'What started as a small initiative has grown into a comprehensive center for neuro-affirming support. We exist to unlock the potential within every individual, proving that with the right support, everyone can play a meaningful role in our society.',
    ],
    missionTitle: 'Mission, Vision & Motto',
    mission: 'To empower neurodivergents through holistic, innovative and neuro-affirming approaches.',
    vision: 'A future where neurodivergents live a life that matters.',
    motto: 'Transform to shine',
    missionNote: 'We exist to unlock the potential within every individual, proving that with the right support, everyone can play a meaningful role in our society.',
    mvLabels: ['Our mission', 'Our vision', 'Our motto'],
    valuesTitle: 'Our Values',
    valuesIntro: 'Our values guide the way we learn, connect, and grow. We chose P.U.P.A — the same letters as our name — because they reflect what we want for every participant, family, and team member.',
    values: [
      ['Purpose', 'I will be excellent and committed to continuous growth.', 'The way I want to learn'],
      ['United', 'I will collaborate and value the contributions of all who are working together.', 'The way I want to be valued'],
      ['Principled', 'I honor integrity, honesty and transparency.', 'The way I want to be trusted'],
      ['Acceptance', 'I embrace diversity and treat everyone with kindness, respect and dignity.', 'The way I want to be embraced'],
    ],
    approachTitle: 'Our Approach',
    approachIntro: 'At PUPA Center, we believe that independence and readiness for adult life are built over time — not overnight. They grow through trust, meaningful experiences, and consistent support. Our holistic approach is continuous and integrated, equipping neurodivergent individuals with the skills, confidence, and opportunities they need to participate fully in their communities and, when they are ready, the world of work.',
    approach: [
      ['Individual-Centered Foundation', 'Our approach is individual-centered and grounded in real-life experiences. We begin by strengthening Life Skills as the foundation for independence in everyday life. Each participant is guided through an Individualized Education Plan (IEP) that reflects their personal needs, strengths, and goals.'],
      ['Social Integration & Collaborative Growth', 'Alongside individual support, participants take part in structured group activities both at PUPA Center and in public settings. This allows them to practice social interaction, collaboration, and daily routines in a safe and supportive environment. We respect that every individual grows at a different pace, adjusting support to each person\u2019s abilities, comfort level, and rhythm of development.'],
      ['Long-Term Readiness & Vision', 'Rather than focusing on fast results, PUPA focuses on long-term readiness and personal growth. We work closely with families and partners to ensure consistency and shared understanding. Guided by our vision, \u201cA future where neurodivergent individuals live a life that matters,\u201d we help each individual move forward with confidence, choice, and a strong foundation for adult life.'],
    ],
  },
  id: {
    metaTitle: 'Tentang PUPA Center — Kisah, Misi & Nilai Kami',
    metaDescription: 'PUPA Center adalah pusat pengembangan untuk anak muda neurodivergen di Tangerang, Indonesia. Kenali kisah kami, pendekatan neuro-affirming kami, dan nilai-nilai yang memandu kerja kami.',
    h1: 'Tentang PUPA Center',
    storyTitle: 'Kisah kami',
    highlights: [
      ['16–25', 'Usia yang kami dampingi'],
      ['3', 'Program inti'],
      ['5 hari', 'Setiap minggu, Sen–Jum'],
      ['Alam Sutera', 'Tangerang, Indonesia'],
    ],
    story: [
      'PUPA lahir dari kegelisahan yang sederhana namun mendalam yang dirasakan banyak keluarga anak muda neurodivergen: masa depan seperti apa yang menanti anak-anak kami ketika kami tidak lagi ada untuk membimbing mereka? Bagi orang tua individu dengan autisme dan kondisi neurodivergen lainnya, pertanyaan ini melampaui sekadar bertahan hidup — ia menyangkut kemandirian, martabat, dan tujuan.',
      'Nama PUPA, yang berasal dari bahasa Latin, berarti kepompong. Nama ini mencerminkan keyakinan kami bahwa pertumbuhan yang bermakna terjadi dalam lingkungan yang aman, terstruktur, dan penuh dukungan — lingkungan yang melindungi, menguatkan, dan mempersiapkan individu tanpa terburu-buru atau memaksakan perubahan.',
      'PUPA Center adalah organisasi yang berfokus pada pendampingan dan pengembangan individu neurodivergen. Kami berkomitmen menghadirkan layanan yang komprehensif bagi individu, keluarga, serta seluruh pihak pendukung dalam ekosistemnya. PUPA lahir sebagai jawaban atas kegelisahan keluarga, di tengah keterbatasan sumber daya terstruktur, kurikulum teruji, dan jalur inklusif bagi anak muda neurodivergen. PUPA memilih pendekatan yang berbeda: merancang program yang membangun kebiasaan, kecakapan hidup, dan kesiapan kerja dengan cara yang menghormati kemampuan, kecepatan, dan standar keberhasilan pribadi setiap individu.',
      'Yang bermula sebagai inisiatif kecil kini telah bertumbuh menjadi pusat pendampingan neuro-affirming yang komprehensif. Kami hadir untuk membuka potensi dalam diri setiap individu, membuktikan bahwa dengan dukungan yang tepat, setiap orang dapat berperan secara bermakna dalam masyarakat.',
    ],
    missionTitle: 'Misi, visi & motto',
    mission: 'Memberdayakan individu neurodivergen melalui pendekatan holistik dan inovatif yang selaras dengan keberagaman neurologis setiap individu.',
    vision: 'Mewujudkan masa depan individu neurodivergen menjalani hidup yang bermakna.',
    motto: 'Transform to shine',
    missionNote: 'Kami mendampingi individu neurodivergen dewasa dengan komitmen pada martabat, inklusi, dan dampak jangka panjang. Lebih dari program, kami memberi ruang dan warna, dengan tujuan membangun kehidupan yang bermakna.',
    mvLabels: ['Misi kami', 'Visi kami', 'Motto kami'],
    valuesTitle: 'Nilai-nilai kami',
    valuesIntro: 'Nilai-nilai kami memandu cara kami belajar, terhubung, dan bertumbuh. Kami memilih P.U.P.A — huruf yang sama dengan nama kami — karena mencerminkan harapan kami bagi setiap peserta, keluarga, dan anggota tim.',
    values: [
      ['Purpose', 'Berkomitmen untuk terus bertumbuh dan berkembang.', 'Cara saya ingin belajar'],
      ['United', 'Berkolaborasi dan menghargai kontribusi semua pihak yang terlibat.', 'Cara saya ingin dihargai'],
      ['Principled', 'Menjaga tinggi integritas, kejujuran, dan transparansi.', 'Cara saya ingin dipercayai'],
      ['Acceptance', 'Merangkul keberagaman dan memperlakukan setiap individu dengan kebaikan, rasa hormat, dan martabat.', 'Cara saya ingin diterima'],
    ],
    approachTitle: 'Pendekatan kami',
    approachIntro: 'Di PUPA Center, kami percaya bahwa kemandirian dan kesiapan menghadapi kehidupan dewasa dibangun secara bertahap — bukan dalam semalam. Semua itu tumbuh melalui kepercayaan, pengalaman yang bermakna, dan dukungan yang konsisten. Pendekatan holistik kami bersifat berkelanjutan dan terintegrasi, membekali individu neurodivergen dengan keterampilan, kepercayaan diri, dan peluang yang mereka butuhkan untuk berperan penuh di tengah masyarakat dan, ketika mereka siap, di dunia kerja.',
    approach: [
      ['PUPA Berorientasi Pada Individu', 'Dengan pemahaman bahwa setiap individu adalah unik, PUPA Center menjadikan penguatan Life Skill sebagai dasar kemandirian dalam kehidupan bermasyarakat — dimulai dari penerapan Individualized Education Plan (IEP) yang disesuaikan dengan kebutuhan setiap individu, serta kemasan klasikal sebagai wujud praktik kolaborasi dalam desain kegiatan di PUPA dan area publik.'],
      ['Integrasi Sosial & Pertumbuhan Kolaboratif', 'Melalui seluruh program PUPA, individu neurodivergen didampingi secara optimal sesuai kapasitas dan ritme masing-masing: pendampingan individual yang menghargai keunikan, pembelajaran berbasis pengalaman nyata, transisi yang terstruktur untuk membangun kemandirian tanpa mengabaikan rasa aman, serta kolaborasi dengan keluarga dan mitra guna memastikan kesinambungan pendampingan.'],
      ['Kesiapan & Visi Jangka Panjang', 'Alih-alih mengejar hasil secara cepat, PUPA berfokus mempersiapkan penguatan unik setiap individu, selaras dengan visi PUPA — \u201cMewujudkan masa depan individu neurodivergen menjalani hidup yang bermakna\u201d — sehingga individu neurodivergen dapat melangkah maju dengan percaya diri dalam fondasi yang kuat menuju kehidupan dewasa.'],
    ],
  },
  ko: {
    metaTitle: 'PUPA 센터 소개 — 이야기, 미션, 가치',
    metaDescription: 'PUPA 센터는 인도네시아 탕에랑에 있는 신경다양성 청년을 위한 성장 지원 센터입니다. 우리의 이야기와 신경긍정(neuro-affirming) 접근, 그리고 일의 바탕이 되는 가치를 소개합니다.',
    h1: 'PUPA 센터 소개',
    storyTitle: '우리의 이야기',
    highlights: [
      ['16–25', '지원 연령대(세)'],
      ['3', '핵심 프로그램'],
      ['주 5일', '월–금, 매주'],
      ['알람 수테라', '인도네시아 탕에랑'],
    ],
    story: [
      'PUPA는 신경다양성 청년을 둔 많은 가족이 품어 온, 단순하지만 깊은 걱정에서 시작되었습니다. 우리가 곁에서 이끌어 줄 수 없게 되었을 때, 우리 아이에게는 어떤 미래가 기다리고 있을까? 자폐를 비롯한 신경다양성 자녀를 둔 부모에게 이 질문은 단순한 생존을 넘어 자립과 존엄, 그리고 삶의 목적에 관한 것입니다.',
      '라틴어에서 온 PUPA라는 이름은 번데기를 뜻합니다. 의미 있는 성장은 안전하고 체계적이며 돌봄이 있는 환경 안에서 일어난다는 우리의 믿음을 담고 있습니다. 변화를 서두르거나 강요하지 않으면서, 개인을 보호하고 단단하게 하며 준비시키는 환경 말입니다.',
      'PUPA는 신경다양성 청년을 위한 체계적인 자원과 검증된 커리큘럼, 포용적인 진로가 부족한 현실 속에서 가족들의 걱정에 대한 응답으로 시작되었습니다. PUPA는 다른 길을 선택했습니다. 각 개인의 능력과 속도, 그리고 저마다의 성공 기준을 존중하는 방식으로 습관과 생활 기술, 취업 준비를 길러 주는 프로그램을 설계하는 것입니다.',
      '작은 시도로 시작한 이 일은 이제 종합적인 신경긍정 지원 센터로 성장했습니다. 우리는 모든 개인 안에 있는 잠재력을 열어 주기 위해 존재하며, 알맞은 지원이 있다면 누구나 사회에서 의미 있는 역할을 할 수 있음을 증명해 가고 있습니다.',
    ],
    missionTitle: '미션, 비전, 모토',
    mission: '전인적이고 혁신적인 신경긍정 접근을 통해 신경다양인의 역량을 키웁니다.',
    vision: '신경다양인이 의미 있는 삶을 살아가는 미래.',
    motto: 'Transform to shine',
    missionNote: '우리는 모든 개인 안에 있는 잠재력을 열어 주기 위해 존재하며, 알맞은 지원이 있다면 누구나 사회에서 의미 있는 역할을 할 수 있음을 증명해 가고 있습니다.',
    mvLabels: ['우리의 미션', '우리의 비전', '우리의 모토'],
    valuesTitle: '우리의 가치',
    valuesIntro: '우리의 가치는 배우고, 연결되고, 성장하는 방식의 길잡이입니다. 센터 이름과 같은 글자인 P.U.P.A를 선택한 것은, 모든 참여자와 가족, 팀원에게 바라는 모습을 담고 있기 때문입니다.',
    values: [
      ['Purpose (목적)', '나는 탁월함을 추구하며 꾸준한 성장에 헌신합니다.', '내가 배우고 싶은 방식'],
      ['United (연합)', '나는 협력하며, 함께 일하는 모든 이의 기여를 소중히 여깁니다.', '내가 존중받고 싶은 방식'],
      ['Principled (원칙)', '나는 정직과 진실함, 투명함을 지킵니다.', '내가 신뢰받고 싶은 방식'],
      ['Acceptance (수용)', '나는 다양성을 껴안고 모든 사람을 친절과 존중, 존엄으로 대합니다.', '내가 받아들여지고 싶은 방식'],
    ],
    approachTitle: '우리의 접근 방식',
    approachIntro: 'PUPA 센터는 자립과 성인기 준비가 하룻밤에 이루어지지 않는다고 믿습니다. 그것은 신뢰와 의미 있는 경험, 꾸준한 지원 속에서 자라납니다. 우리의 전인적 접근은 연속적이고 통합적으로 설계되어, 신경다양인이 지역사회에 온전히 참여하고 준비가 되었을 때 일의 세계로 나아가는 데 필요한 기술과 자신감, 기회를 갖추도록 돕습니다.',
    approach: [
      ['개인 중심의 기초', '우리의 접근은 개인 중심이며 실제 생활 경험에 뿌리를 둡니다. 일상 속 자립의 토대가 되는 생활 기술을 다지는 것에서 시작하며, 모든 참여자는 각자의 필요와 강점, 목표를 반영한 개별화교육계획(IEP)에 따라 안내받습니다.'],
      ['사회적 통합과 함께 자라는 성장', '개별 지원과 함께, 참여자들은 PUPA 센터 안팎의 공공 환경에서 체계적인 그룹 활동에 참여합니다. 안전하고 지지적인 환경에서 사회적 상호작용과 협력, 일상 루틴을 연습할 수 있습니다. 우리는 모든 사람이 서로 다른 속도로 성장한다는 것을 존중하며, 각자의 능력과 편안함, 발달 리듬에 맞추어 지원을 조정합니다.'],
      ['장기적 준비와 비전', 'PUPA는 빠른 결과보다 장기적인 준비와 개인의 성장에 집중합니다. 가족 및 파트너와 긴밀히 협력하여 일관성과 공동의 이해를 지켜 갑니다. \u201c신경다양인이 의미 있는 삶을 살아가는 미래\u201d라는 비전 아래, 각 개인이 자신감과 선택권, 그리고 성인기의 단단한 기초를 가지고 앞으로 나아가도록 돕습니다.'],
    ],
  },
};
const c = content[lang] ?? content.en;

// P.U.P.A big-letter treatment metadata (shared across languages)
const pupaLetters = ['P', 'U', 'P', 'A'];
const pupaColors = ['var(--orange-500)', 'var(--teal-500)', 'var(--orange-700)', 'var(--teal-900)'];
const pupaIcons = [
  // Purpose — target
  '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1" fill="currentColor"/>',
  // United — people
  '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="10" r="2.5"/><path d="M3 19v-1a6 6 0 0 1 12 0v1"/><path d="M15 19v-1a4 4 0 0 1 6 0v1"/>',
  // Principled — shield check
  '<path d="M12 3l7 3v5c0 4-3 7-7 9-4-2-7-5-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  // Acceptance — heart
  '<path d="M12 21s-7-4.35-9.5-8.5C1 9 3 5.5 6.5 5.5c2 0 3.5 1.5 5.5 3.5 2-2 3.5-3.5 5.5-3.5C21 5.5 23 9 21.5 12.5 19 16.65 12 21 12 21z"/>',
];
---
<Layout lang={lang} routeKey="about" title={c.metaTitle} description={c.metaDescription}>
  <section class="page-head">
    <div class="wrap">
      <h1>{c.h1}</h1>
    </div>
  </section>

  <section class="about-sec" id="story">
    <div class="wrap story-wrap">
      <div>
        <h2>{c.storyTitle}</h2>
        {c.story.map((par) => <p class="story-p">{par}</p>)}
      </div>
      <img class="blob about-photo" src="/images/about-our-story.jpg" alt="" loading="lazy" width="480" height="420" />
    </div>
    <div class="wrap">
      <div class="hl-strip">
        {c.highlights.map((h) => (
          <div class="hl-item"><span class="hl-num">{h[0]}</span><span class="hl-label">{h[1]}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="group-band" aria-hidden="true">
    <img src="/images/pupa-group-9696.jpg" alt="" loading="lazy" />
  </section>

  <section class="about-sec alt" id="mission">
    <div class="wrap">
      <h2>{c.missionTitle}</h2>
      <div class="mv-grid">
        <div class="mv-card mv-1"><p class="mv-label">{c.mvLabels[0]}</p><p class="mv-text">{c.mission}</p></div>
        <div class="mv-card mv-2"><p class="mv-label">{c.mvLabels[1]}</p><p class="mv-text">{c.vision}</p></div>
        <div class="mv-card mv-3"><p class="mv-label">{c.mvLabels[2]}</p><p class="mv-text motto">{c.motto}</p></div>
      </div>
      <p class="story-p">{c.missionNote}</p>
      <div class="values-block">
        <h3 id="values" class="values-title">{c.valuesTitle}</h3>
        <p class="values-intro">{c.valuesIntro}</p>

        <div class="pupa-letters" aria-hidden="true">
          {c.values.map((v, i) => (
            <div class="letter-col" style={`color:${pupaColors[i]}`}>
              <span class="letter-label">{v[0]}</span>
              <span class="big-letter">{pupaLetters[i]}<span class="letter-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={pupaIcons[i]}></svg></span></span>
            </div>
          ))}
        </div>

        <div class="value-defs">
          {c.values.map((v, i) => (
            <div class="value-def" style={`--accent:${pupaColors[i]}`}>
              <h4 class="vd-name" style={`color:${pupaColors[i]}`}>{v[0]}</h4>
              <p class="vd-text">{v[1]}</p>
              <span class="value-chip">{v[2]}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="about-sec alt" id="approach">
    <div class="wrap approach-grid">
      <div>
        <h2>{c.approachTitle}</h2>
        <p class="story-p">{c.approachIntro}</p>
      </div>
      <div class="pillars">
        {c.approach.map((a, i) => (
          <details open={i === 0}>
            <summary>{a[0]}</summary>
            <p>{a[1]}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
.page-head{background:var(--cream);padding:64px 0 48px;border-bottom:1px solid var(--line)}
.about-sec{padding:56px 0}
.story-wrap{display:grid;grid-template-columns:1.15fr .85fr;gap:48px;align-items:center}
.about-photo{width:100%;aspect-ratio:8/7;box-shadow:0 14px 34px rgba(11,68,65,.12)}
.group-band img{width:100%;height:480px;object-fit:cover;object-position:center 28%;display:block}
@media (max-width:960px){.story-wrap{grid-template-columns:1fr}.group-band img{height:300px}}
.about-sec.alt{background:var(--surface);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.story-p{margin:14px 0;color:var(--ink-soft)}
.about-sec h3{margin:32px 0 8px}
