---
import Layout from '../layouts/Layout.astro';
import { home } from '../i18n/home';
import { routes, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = home[lang];
const p = (key: string) => (routes[key] ?? routes.home)[lang];

const alts = {
  en: {
    hero: 'PUPA Center participants and mentors together during a group activity',
    strip: ['A participant practicing cooking skills', 'A participant painting in art class', 'A participant learning barista skills', 'Participants gardening outdoors', 'Participants during a group activity'],
    families: 'Participants and mentors walking together outdoors',
    donors: 'The PUPA Center community together',
    volunteers: 'A mentor supporting a participant in art class',
    mandiri: 'Participants building life skills through hands-on horticulture',
    karya: 'A participant working in a sensory-supportive workspace',
    access: 'A private meeting room at PUPA Center',
    banner: 'Aerial view of the PUPA Center neighborhood in Alam Sutera',
    donate: 'Participants at a PUPA Center community event',
  },
  id: {
    hero: 'Peserta dan mentor PUPA Center bersama dalam kegiatan kelompok',
    strip: ['Peserta berlatih keterampilan memasak', 'Peserta melukis di kelas seni', 'Peserta belajar keterampilan barista', 'Peserta berkebun di luar ruangan', 'Peserta dalam kegiatan kelompok'],
    families: 'Peserta dan mentor berjalan bersama di luar ruangan',
    donors: 'Komunitas PUPA Center bersama-sama',
    volunteers: 'Mentor mendampingi peserta di kelas seni',
    mandiri: 'Peserta membangun kecakapan hidup melalui kegiatan berkebun',
    karya: 'Peserta bekerja di ruang kerja ramah sensorik',
    access: 'Ruang pertemuan privat di PUPA Center',
    banner: 'Pemandangan udara kawasan PUPA Center di Alam Sutera',
    donate: 'Peserta dalam acara komunitas PUPA Center',
  },
  ko: {
    hero: '그룹 활동 중인 PUPA 센터 참여자와 멘토들',
    strip: ['요리 기술을 연습하는 참여자', '미술 수업에서 그림을 그리는 참여자', '바리스타 기술을 배우는 참여자', '야외에서 원예 활동을 하는 참여자들', '그룹 활동 중인 참여자들'],
    families: '야외에서 함께 걷는 참여자와 멘토들',
    donors: '함께 모인 PUPA 센터 커뮤니티',
    volunteers: '미술 수업에서 참여자를 돕는 멘토',
    mandiri: '원예 실습으로 생활 기술을 익히는 참여자들',
    karya: '감각 친화적인 작업 공간에서 일하는 참여자',
    access: 'PUPA 센터의 프라이빗 회의실',
    banner: '알람 수테라의 PUPA 센터 주변을 담은 항공 사진',
    donate: 'PUPA 센터 커뮤니티 행사에 참여한 사람들',
  },
}[lang];

const stageImgs = [
  { src: '/images/afm-9646.jpg', alt: alts.mandiri },
  { src: '/images/a6701715.jpg', alt: alts.karya },
  { src: '/images/afm-9733.jpg', alt: alts.access },
];
const doorImgs = [
  { src: '/images/img-0559.jpg', alt: alts.families },
  { src: '/images/pupa-group-9707.jpg', alt: alts.donors },
  { src: '/images/a6701639.jpg', alt: alts.volunteers },
];
const strip = [
  '/images/a6701241.jpg', '/images/a6701521-edited.jpg', '/images/a6701212.jpg',
  '/images/afm-9646.jpg', '/images/a6702069.jpg',
];
const storyImgs = ['/images/afm-9305.jpg', '/images/afm-9263.jpg', '/images/afm-8982.jpg'];
---
<Layout lang={lang} routeKey="home" title={c.metaTitle} description={c.metaDescription}>

  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">{c.eyebrow}</span>
        <h1>{c.heroTitle}</h1>
        <p class="lede">{c.heroLede}</p>
        <div class="hero-ctas">
          <a class="btn btn-primary" href="https://wa.me/62818533698" rel="noopener">{c.ctaVisit}</a>
          <a class="btn btn-primary" href={p('programs')}>{c.ctaPrograms}</a>
        </div>
      </div>
      <div class="hero-photo">
        <img class="blob" src="/images/a6701896.jpg" alt={alts.hero} width="640" height="560" fetchpriority="high" />
        <img class="butterfly" src="/images/brand/pupa-butterfly.png" alt="" aria-hidden="true" width="112" height="83" />
      </div>
    </div>
  </section>

  <!-- ACTIVITY PHOTO STRIP -->
  <section class="strip">
    <div class="strip-row">
      {strip.map((src, i) => <img src={src} alt={alts.strip[i]} loading="lazy" width="320" height="240" />)}
    </div>
  </section>

  <!-- DOORWAYS -->
  <section class="doorways">
    <div class="wrap">
      <div class="section-head">
        <h2>{c.doorwaysTitle}</h2>
        <p>{c.doorwaysLede}</p>
      </div>
      <div class="card-grid">
        {c.doorways.map((d: any, i: number) => (
          <article class="card photo-card">
            <img src={doorImgs[i].src} alt={doorImgs[i].alt} loading="lazy" width="380" height="240" />
            <div class="photo-card-body">
              <h3>{d.title}</h3>
              <p>{d.body}</p>
              <a class="card-link" href={p(d.routeKey)}>{d.link} →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRAMS: GROWTH PATH -->
  <section class="programs-band" id="programs">
    <div class="wrap">
      <div class="section-head">
        <h2>{c.programsTitle}</h2>
        <p>{c.programsLede}</p>
      </div>
      <div class="path">
        {c.stages.map((s: any, i: number) => (
          <article class="stage">
            <img class="stage-img" src={stageImgs[i].src} alt={stageImgs[i].alt} loading="lazy" width="380" height="220" />
            <div class="stage-body">
              <span class="stage-num" aria-hidden="true">{i + 1}</span>
              <p class="stage-tag">{s.tag}</p>
              <h3>{s.name}</h3>
              <p>{s.body}</p>
              <a href={p('programs') + s.anchor}>{s.link} →</a>
            </div>
          </article>
        ))}
      </div>
      <p class="path-note">
        {c.pathNotePrefix}<a href={p('programs') + '#extracurriculars'}>{c.pathNoteLink}</a>{c.pathNoteSuffix}
      </p>
    </div>
  </section>

  <!-- AT A GLANCE -->
  <section class="impact">
    <div class="wrap">
      <div class="section-head">
        <h2>{c.impactTitle}</h2>
        <p>{c.impactLede}</p>
      </div>
      <div class="impact-grid">
        {c.stats.map((s: any) => (
          <div class="stat">
            <p class="num">{s.num}</p>
            <p class="label">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FULL-BLEED MISSION BANNER -->
  <section class="banner">
    <img src="/images/dji-20251018105020-0646-d-pa2.jpg" alt={alts.banner} loading="lazy" />
    <div class="banner-overlay">
      <p class="banner-quote">{c.bannerQuote}</p>
    </div>
  </section>

  <!-- GROWTH JOURNEYS -->
  <section class="story">
    <div class="wrap story-grid">
      <div class="story-photos" aria-hidden="true">
        <img class="blob" src={storyImgs[0]} alt="" loading="lazy" width="300" height="300" />
        <img class="blob-alt" src={storyImgs[1]} alt="" loading="lazy" width="240" height="240" />
        <img class="blob" src={storyImgs[2]} alt="" loading="lazy" width="200" height="200" />
      </div>
      <div>
        <h2>{c.storyTitle}</h2>
        <blockquote>
          {c.storyQuote}
          <footer>{c.storyAttribution}</footer>
        </blockquote>
        <a class="btn btn-primary story-cta" href={p('stories')}>{c.storyCta}</a>
      </div>
    </div>
  </section>

  <!-- DONATE -->
  <section class="donate-band" id="donate">
    <div class="wrap">
      <div class="donate-inner">
        <div>
          <h2>{c.donateTitle}</h2>
          <p>{c.donateLede}</p>
          <a class="btn btn-donate" href={p('donate')}>{c.donateCta}</a>
        </div>
        <img class="blob donate-photo" src="/images/a6702295.jpg" alt={alts.donate} loading="lazy" width="420" height="360" />
      </div>
    </div>
  </section>

</Layout>

<style>
/* HERO — warm cream with brand corner blobs */
.hero{background:var(--cream);border-bottom:1px solid #EFE4D2;position:relative;overflow:hidden}
.hero::before{content:"";position:absolute;left:-90px;bottom:-140px;width:380px;height:300px;background:var(--peach);border-radius:52% 48% 55% 45%/48% 55% 45% 52%}
.hero::after{content:"";position:absolute;right:-110px;top:-140px;width:360px;height:300px;background:var(--sage);border-radius:45% 55% 48% 52%/55% 45% 52% 48%}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:56px;align-items:center;padding-top:72px;padding-bottom:80px;position:relative;z-index:1}
.lede{font-size:1.15rem;color:var(--ink-soft);margin:20px 0 32px}
.hero-ctas{display:flex;flex-wrap:wrap;gap:14px}
.hero-photo{position:relative}
.hero-photo .blob{width:100%;aspect-ratio:8/7;box-shadow:0 18px 44px rgba(11,68,65,.16)}
.butterfly{position:absolute;width:112px;right:-18px;top:-30px;transform:rotate(8deg)}

/* PHOTO STRIP */
.strip{background:var(--surface);border-bottom:1px solid var(--line);padding:14px 0}
.strip-row{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;max-width:1400px;margin:0 auto;padding:0 12px}
.strip-row img{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:var(--radius)}

/* DOORWAYS with photos */
.doorways{padding:72px 0}
.photo-card{padding:0;overflow:hidden}
.photo-card img{width:100%;aspect-ratio:16/10;object-fit:cover}
.photo-card-body{padding:22px 24px 26px;display:flex;flex-direction:column;gap:10px;flex-grow:1}
.photo-card-body p{flex-grow:1}

/* PROGRAMS band */
.programs-band{background:var(--teal-900);color:#F4FAF9;padding:80px 0}
.programs-band h2,.programs-band h3{color:#fff}
.programs-band .section-head p{color:#C8DEDC}
.path{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;align-items:stretch}
.stage{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);border-radius:var(--radius-lg);overflow:hidden;display:flex;flex-direction:column}
.stage-img{width:100%;aspect-ratio:16/9;object-fit:cover}
.stage-body{padding:24px 26px 28px;display:flex;flex-direction:column;flex-grow:1}
.stage-num{display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;background:var(--orange-500);color:#2B1503;font-family:var(--font-display);font-weight:700;font-size:1.15rem;margin-bottom:14px}
.stage-body h3{margin:0 0 10px}
.stage-body p{font-size:1rem;color:#C8DEDC;margin:0 0 18px;flex-grow:1}
.stage-tag{font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#9BC4C0;white-space:nowrap;margin:0 0 10px}
.stage-body a{color:#FFD9B3;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;min-height:44px;margin-top:auto}
.stage-body a:hover{text-decoration:underline}
.path-note{margin-top:28px;font-size:1rem;color:#C8DEDC;max-width:72ch}
.path-note a{color:#FFD9B3;font-weight:600}

/* AT A GLANCE */
.impact{padding:72px 0;background:var(--cream)}
.impact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:8px}
.stat{background:var(--surface);border:1px solid #EFE4D2;border-radius:var(--radius-lg);padding:28px}
.stat .num{font-family:var(--font-display);font-size:2.6rem;font-weight:700;color:var(--teal-700);line-height:1.1}
.stat .label{color:var(--ink-soft);font-size:1rem;margin-top:6px}

/* FULL-BLEED BANNER */
.banner{position:relative}
.banner img{width:100%;height:420px;object-fit:cover;display:block}
.banner-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(11,68,65,.25),rgba(11,68,65,.62));display:flex;align-items:center;justify-content:center;padding:24px}
.banner-quote{font-family:var(--font-display);font-size:clamp(1.5rem,3.4vw,2.4rem);font-weight:700;color:#fff;text-align:center;max-width:32ch;line-height:1.3;text-wrap:balance;text-shadow:0 2px 14px rgba(0,0,0,.35)}

/* GROWTH JOURNEYS */
.story{background:var(--surface);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:80px 0}
.story-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:56px;align-items:center}
.story-photos{position:relative;height:380px}
.story-photos img{position:absolute;box-shadow:0 12px 30px rgba(11,68,65,.14)}
.story-photos img:nth-child(1){width:62%;left:0;top:0;aspect-ratio:1;}
.story-photos img:nth-child(2){width:46%;right:0;top:34%;aspect-ratio:1;}
.story-photos img:nth-child(3){width:38%;left:14%;bottom:0;aspect-ratio:1;}
blockquote{font-family:var(--font-display);font-size:1.25rem;font-weight:500;line-height:1.55;border:none;letter-spacing:-0.005em;margin-top:16px}
blockquote footer{font-family:'Inter',sans-serif;font-size:.95rem;font-weight:500;color:var(--ink-soft);margin-top:16px}
.story-cta{margin-top:28px}

/* DONATE */
.donate-band{padding:80px 0;background:var(--cream)}
.donate-inner{background:var(--surface);border:1px solid #F2D9BE;border-radius:var(--radius-lg);padding:48px;display:grid;grid-template-columns:1.15fr .85fr;gap:44px;align-items:center}
.donate-inner p{color:var(--ink-soft);margin:14px 0 26px}
.donate-photo{width:100%;aspect-ratio:7/6}

@media (max-width:960px){
  .hero-grid,.story-grid,.donate-inner{grid-template-columns:1fr}
  .path,.impact-grid{grid-template-columns:1fr}
  .strip-row{grid-template-columns:repeat(2,1fr)}
  .strip-row img:nth-child(n+5){display:none}
  .story-photos{height:300px}
  .banner img{height:300px}
  .butterfly{width:80px;right:0;top:-20px}
}
</style>
