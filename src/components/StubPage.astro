---
import Layout from '../layouts/Layout.astro';
import { useTranslations, routes, type Lang } from '../i18n/ui';

interface Props { lang: Lang; routeKey: string; title: string; }
const { lang, routeKey, title } = Astro.props;
const t = useTranslations(lang);
---
<Layout lang={lang} routeKey={routeKey} title={`${title} | PUPA Center`} description={t('stub.body')}>
  <section class="stub">
    <div class="wrap">
      <span class="eyebrow">{t('stub.title')}</span>
      <h1>{title}</h1>
      <p>{t('stub.body')}</p>
      <a class="btn btn-primary" href={routes.home[lang]}>{t('stub.back')}</a>
    </div>
  </section>
</Layout>

<style>
.stub{padding:96px 0 120px}
.stub p{color:var(--ink-soft);margin:20px 0 32px}
</style>
