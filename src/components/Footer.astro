---
import { useTranslations, routes, type Lang } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const p = (key: string) => (routes[key] ?? routes.home)[lang];
const year = new Date().getFullYear();
const wa = 'https://wa.me/62818533698';
---
<footer class="site-footer">
  <!-- Mission band (centered, top) -->
  <div class="foot-band">
    <div class="wrap">
      <img class="band-logo" src="/images/brand/pupa-logo-white.png" alt="PUPA" width="54" height="70" />
      <p class="band-text">{t('footer.missionBand')}</p>
    </div>
  </div>

  <!-- Link columns -->
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <span class="brand-name">{t('site.name')}</span>
        <p class="tagline">Transform to Shine</p>
        <p class="blurb">{t('footer.blurb')}</p>
      </div>
      <div>
        <h3>{t('footer.programs')}</h3>
        <ul>
          <li><a href={p('programs')}>{t('nav.programs.overview')}</a></li>
          <li><a href={p('programs') + '#mandiri'}>Mandiri</a></li>
          <li><a href={p('programs') + '#karya'}>Karya</a></li>
          <li><a href={p('programs') + '#access'}>Access</a></li>
          <li><a href={p('programs') + '#extracurriculars'}>{t('nav.programs.extracurriculars')}</a></li>
        </ul>
      </div>
      <div>
        <h3>{t('footer.about')}</h3>
        <ul>
          <li><a href={p('about')}>{t('nav.about.story')}</a></li>
          <li><a href={p('about') + '#mission'}>{t('nav.about.mission')}</a></li>
          <li><a href={p('board')}>{t('nav.about.board')}</a></li>
          <li><a href={p('team')}>{t('nav.about.team')}</a></li>
          <li><a href={p('stories')}>{t('nav.resources.stories')}</a></li>
        </ul>
      </div>
      <div>
        <h3>{t('footer.action')}</h3>
        <ul>
          <li><a href={p('donate')}>{t('nav.donate')}</a></li>
          <li><a href={p('getInvolved') + '#volunteer'}>{t('nav.involved.volunteer')}</a></li>
          <li><a href={p('getInvolved') + '#partner'}>{t('nav.involved.partner')}</a></li>
          <li><a href={p('enrollment')}>{t('nav.enrollment.how')}</a></li>
        </ul>
      </div>
    </div>

    <!-- Contact-action row: WhatsApp CTA + inline social (moved to bottom) -->
    <div class="foot-cta">
      <div class="cta-grid">
        <div class="cta-copy">
          <h2>{t('footer.ctaHeading')}</h2>
          <p>{t('footer.ctaBlurb')}</p>
        </div>
        <div class="cta-actions">
          <a class="cta-pill cta-pill-accent" href={wa} rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12 4a7.94 7.94 0 0 0-6.9 11.9L4 20l4.2-1.1A7.9 7.9 0 0 0 12 19.9a7.94 7.94 0 0 0 5.6-13.58zM12 18.5a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.5.65.67-2.43-.16-.25a6.59 6.59 0 1 1 12.2-3.51A6.6 6.6 0 0 1 12 18.5zm3.62-4.94c-.2-.1-1.17-.58-1.35-.64s-.31-.1-.44.1-.51.64-.62.77-.23.15-.43.05a5.4 5.4 0 0 1-1.59-.98 6 6 0 0 1-1.1-1.37c-.11-.2 0-.3.09-.4l.3-.35a1.36 1.36 0 0 0 .2-.33.37.37 0 0 0 0-.35c-.05-.1-.44-1.07-.6-1.46s-.32-.34-.44-.34h-.38a.72.72 0 0 0-.52.24 2.19 2.19 0 0 0-.69 1.63A3.82 3.82 0 0 0 8.1 12a8.7 8.7 0 0 0 3.32 2.93c.46.2.82.32 1.1.41a2.66 2.66 0 0 0 1.22.08 2 2 0 0 0 1.31-.92 1.63 1.63 0 0 0 .11-.92c-.04-.09-.17-.14-.37-.24z"/></svg>
            <span>{t('footer.ctaContact')}</span>
          </a>
          <div class="cta-social">
            <a href="https://www.instagram.com/pupa.center" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"/></svg>
            </a>
            <a href="https://www.youtube.com/@PUPACenter" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
            </a>
            <a href="mailto:info@pupacenter.org" aria-label="Email">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="foot-bottom">
      <p>© {year} {t('footer.legalName')}. {t('footer.rights')}</p>
      <p class="foot-legal"><a href={routes.privacy[lang]}>{t('footer.privacy')}</a><a href={routes.accessibility[lang]}>{t('footer.accessibility')}</a></p>
    </div>
  </div>
</footer>

<style>
.site-footer{background:var(--teal-900);color:#C8DEDC;font-size:1rem}

/* Mission band */
.foot-band{border-bottom:1px solid rgba(255,255,255,.12);padding:30px 0;text-align:center}
.band-logo{height:52px;width:auto;margin:0 auto 14px;opacity:.95}
.band-text{max-width:72ch;margin:0 auto;color:#EAF3F1;font-size:1rem;line-height:1.55;font-family:'Fraunces',serif;font-weight:500}

/* Contact CTA row */
.foot-cta{border-top:1px solid rgba(255,255,255,.12);padding:36px 0}
.cta-grid{display:grid;grid-template-columns:1.5fr 1fr;gap:44px;align-items:center}
.cta-copy h2{color:#fff;font-size:1.05rem;font-weight:700;margin-bottom:8px}
.cta-copy p{color:#C8DEDC;max-width:none;font-size:.92rem;text-wrap:normal}
.cta-actions{display:flex;align-items:center;gap:16px;flex-wrap:wrap;justify-content:flex-end}
.cta-pill{display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);color:#fff;padding:15px 24px;border-radius:999px;text-decoration:none;font-weight:600;min-height:44px;transition:background .2s ease,border-color .2s ease}
.cta-pill:hover{background:rgba(255,255,255,.14)}
.cta-pill svg{width:20px;height:20px;flex:none}
.cta-pill-accent{background:var(--orange-500);color:#2B1503;border-color:var(--orange-500)}
.cta-pill-accent:hover{background:var(--orange-700);border-color:var(--orange-700);color:#fff}
.cta-social{display:flex;gap:10px}
.cta-social a{display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.1);color:#fff;transition:background .2s ease}
.cta-social a:hover{background:var(--orange-500);color:#2B1503}
.cta-social svg{width:20px;height:20px}

/* Link columns */
.foot-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:28px;padding:40px 0 28px}
.brand-name{font-family:'Fraunces',serif;font-weight:700;font-size:1.15rem;color:#fff;display:block}
.tagline{font-size:.82rem;letter-spacing:.06em;color:#9BC4C0;margin-top:2px!important}
.blurb{margin-top:12px;max-width:34ch;color:#C8DEDC;font-size:.92rem;line-height:1.55}
h3{color:var(--orange-500);font-size:.95rem;font-family:'Fraunces',serif;font-weight:600;letter-spacing:0;text-transform:none;margin-bottom:10px}
ul{list-style:none}
li a{display:inline-flex;align-items:center;min-height:30px;padding:2px 0;font-size:.92rem;color:#C8DEDC;text-decoration:none}
li a:hover{color:#fff;text-decoration:underline}

/* Connect row */
.foot-connect{border-top:1px solid rgba(255,255,255,.12);padding:28px 0;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.connect-label{font-weight:700;color:#fff;margin:0;font-size:1rem}
.connect-icons{display:flex;gap:12px}
.connect-icons a{display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.1);color:#fff;transition:background .2s ease}
.connect-icons a:hover{background:var(--orange-500);color:#2B1503}
.connect-icons svg{width:20px;height:20px}

.foot-bottom{border-top:1px solid rgba(255,255,255,.12);padding:22px 0 32px;display:flex;flex-wrap:wrap;gap:16px;justify-content:space-between;font-size:.82rem}
.foot-bottom a{color:#C8DEDC}
.foot-legal{display:flex;gap:20px}

@media (max-width:960px){
  .cta-grid{grid-template-columns:1fr;gap:24px}.cta-actions{justify-content:flex-start}
  .foot-grid{grid-template-columns:1fr 1fr;gap:28px}
}
@media (max-width:560px){
  .cta-actions{grid-template-columns:1fr}
  .foot-grid{grid-template-columns:1fr}
}
</style>
