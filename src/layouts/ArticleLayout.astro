---
import Layout from '../layouts/Layout.astro';
import { type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  routeKey: string;
  title: string;
  seoTitle?: string;     // shorter title for the <title> tag; on-page h1 keeps the full title
  description: string;
  date?: Date;
  altUrls?: { en: string; id: string; ko: string };
  image?: string;
  imageAlt?: string;     // descriptive alt for the hero photo
  backHref: string;
  backLabel: string;
}
const { lang, routeKey, title, seoTitle, description, date, image, imageAlt, backHref, backLabel, altUrls } = Astro.props;
const fmtDate = date?.toLocaleDateString(lang === 'id' ? 'id-ID' : lang === 'ko' ? 'ko-KR' : 'en-US', { year: 'numeric', month: 'long' });

// Article structured data (BlogPosting) — helps search engines and AI
// assistants recognize each post/story as a citable article.
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.pupacenter.org';
const pageUrl = site + (altUrls?.[lang] ?? Astro.url.pathname);
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  inLanguage: lang === 'id' ? 'id-ID' : lang === 'ko' ? 'ko-KR' : 'en-US',
  ...(date ? { datePublished: date.toISOString().slice(0, 10) } : {}),
  ...(image ? { image: site + image } : {}),
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  author: { '@type': 'Organization', name: 'PUPA Center', url: site },
  publisher: {
    '@type': 'Organization',
    name: 'PUPA Center',
    logo: { '@type': 'ImageObject', url: site + '/images/brand/pupa-logo.png' },
  },
};
---
<Layout lang={lang} routeKey={routeKey} altUrls={altUrls} title={`${seoTitle ?? title} | PUPA Center`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  <article class="article">
    <header class="article-head">
      <div class="wrap narrow">
        <a class="back" href={backHref}>← {backLabel}</a>
        <h1>{title}</h1>
        {fmtDate && <p class="date">{fmtDate}</p>}
      </div>
    </header>
    {image && (
      <div class="wrap narrow">
        <img class="hero-img" src={image} alt={imageAlt ?? ''} loading="lazy" />
      </div>
    )}
    <div class="wrap narrow article-body">
      <slot />
    </div>
  </article>
</Layout>

<style>
.narrow{max-width:760px}
.article-head{background:var(--cream);padding:48px 0 36px;border-bottom:1px solid var(--line);margin-bottom:32px}
.back{display:inline-flex;align-items:center;min-height:44px;font-weight:600;text-decoration:none;color:var(--teal-700)}
.back:hover{text-decoration:underline}
.date{color:var(--ink-soft);margin-top:10px;font-size:.95rem}
.hero-img{width:100%;border-radius:var(--radius-lg);margin-bottom:28px;aspect-ratio:4/3;object-fit:cover;object-position:center 20%}
.article-body{padding-bottom:80px}
.article-body :global(p){margin:16px 0;color:var(--ink)}
.article-body :global(h2),.article-body :global(h3){margin:32px 0 12px}
.article-body :global(a){color:var(--teal-700);font-weight:600}
.article-body :global(img){border-radius:var(--radius);margin:20px 0}
</style>
