---
import Layout from '../layouts/Layout.astro';
import { type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  routeKey: string;
  title: string;
  description: string;
  date?: Date;
  image?: string;
  backHref: string;
  backLabel: string;
}
const { lang, routeKey, title, description, date, image, backHref, backLabel } = Astro.props;
const fmtDate = date?.toLocaleDateString(lang === 'id' ? 'id-ID' : lang === 'ko' ? 'ko-KR' : 'en-US', { year: 'numeric', month: 'long' });
---
<Layout lang={lang} routeKey={routeKey} title={`${title} | PUPA Center`} description={description}>
  <article class="article">
    <header class="article-head">
      <div class="wrap narrow">
        <a class="back" href={backHref}>← {backLabel}</a>
        <h1>{title}</h1>
        {fmtDate && <p class="date">{fmtDate}</p>}
      </div>
    </header>
    {image && (
      <div class="wrap narrow">
        <img class="hero-img" src={image} alt="" loading="lazy" />
      </div>
    )}
    <div class="wrap narrow article-body">
      <slot />
    </div>
  </article>
</Layout>

<style>
.narrow{max-width:760px}
.article-head{background:var(--cream);padding:48px 0 36px;border-bottom:1px solid var(--line);margin-bottom:32px}
.back{display:inline-flex;align-items:center;min-height:44px;font-weight:600;text-decoration:none;color:var(--teal-700)}
.back:hover{text-decoration:underline}
.date{color:var(--ink-soft);margin-top:10px;font-size:.95rem}
.hero-img{width:100%;border-radius:var(--radius-lg);margin-bottom:28px;aspect-ratio:4/3;object-fit:cover;object-position:center 20%}
.article-body{padding-bottom:80px}
.article-body :global(p){margin:16px 0;color:var(--ink)}
.article-body :global(h2),.article-body :global(h3){margin:32px 0 12px}
.article-body :global(a){color:var(--teal-700);font-weight:600}
.article-body :global(img){border-radius:var(--radius);margin:20px 0}
</style>
