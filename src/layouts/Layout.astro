---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { routes, useTranslations, type Lang } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  lang: Lang;
  routeKey: string;      // key into the routes map, powers hreflang + language toggle
  title: string;
  description: string;
}
const { lang, routeKey, title, description } = Astro.props;
const t = useTranslations(lang);
const route = routes[routeKey] ?? routes.home;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.pupacenter.org';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={site + route[lang]} />
  <link rel="alternate" hreflang="en" href={site + route.en} />
  <link rel="alternate" hreflang="id" href={site + route.id} />
  <link rel="alternate" hreflang="x-default" href={site + route.en} />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={site + '/images/brand/og-image.jpg'} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#0F6B66" />
  <meta property="og:locale" content={lang === 'id' ? 'id_ID' : 'en_US'} />
  <meta property="og:locale:alternate" content={lang === 'id' ? 'en_US' : 'id_ID'} />
  <meta property="og:site_name" content="PUPA Center" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'EducationalOrganization',
    name: 'PUPA Center',
    alternateName: 'Yayasan PUPA Center',
    url: 'https://www.pupacenter.org',
    logo: 'https://www.pupacenter.org/images/brand/pupa-logo.png',
    image: 'https://www.pupacenter.org/images/brand/og-image.jpg',
    description: lang === 'id'
      ? 'Pusat pengembangan kecakapan hidup dan kesiapan kerja bagi anak muda neurodivergen di Tangerang, Indonesia.'
      : 'A development center for life skills and work readiness for neurodivergent young adults in Tangerang, Indonesia.',
    slogan: 'Transform to shine',
    email: 'info@pupacenter.org',
    telephone: '+62-818-533-698',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Ruko Prominence Blok 38E No. 42-43, Jl. Sutera Barat Boulevard, Alam Sutera',
      addressLocality: 'Tangerang',
      addressRegion: 'Banten',
      postalCode: '15143',
      addressCountry: 'ID',
    },
    geo: { '@type': 'GeoCoordinates', latitude: -6.2288, longitude: 106.6539 },
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'],
      opens: '09:00', closes: '15:00',
    },
    areaServed: { '@type': 'Place', name: 'Tangerang, Banten, Indonesia' },
    sameAs: [
      'https://www.instagram.com/pupa.center',
      'https://www.youtube.com/@PUPACenter',
    ],
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <a class="skip-link" href="#main">{t('a11y.skip')}</a>
  <Header lang={lang} routeKey={routeKey} />
  <main id="main">
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
