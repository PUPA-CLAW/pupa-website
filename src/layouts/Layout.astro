---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityToolbar from '../components/AccessibilityToolbar.astro';
import { routes, useTranslations, type Lang } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  lang: Lang;
  routeKey: string;      // key into the routes map, powers hreflang + language toggle
  altUrls?: { en: string; id: string; ko: string };  // per-page overrides (article translations)
  title: string;
  description: string;
}
const { lang, routeKey, title, description, altUrls } = Astro.props;
const t = useTranslations(lang);
const route = altUrls ?? (routes[routeKey] ?? routes.home);
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.pupacenter.org';

// First-visit language gateway: only on the EN homepage ('/'). Respects a stored
// explicit choice, otherwise routes by browser language. Runtime path guard keeps
// this inert if the markup is ever served at another URL (e.g. a CDN 404 fallback).
const isHomeGateway = Astro.url.pathname === '/';
const langRedirectScript = `(function(){try{
if(location.pathname!=='/')return;
var s=localStorage.getItem('pupa-lang');
if(s==='id'){location.replace('/id/');return}
if(s==='ko'){location.replace('/ko/');return}
if(s)return;
var l=((navigator.languages&&navigator.languages[0])||navigator.language||'').toLowerCase();
if(l==='id'||l.indexOf('id-')===0||l==='in'||l.indexOf('in-')===0){location.replace('/id/')}
else if(l==='ko'||l.indexOf('ko-')===0){location.replace('/ko/')}
}catch(e){}})();`;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {isHomeGateway && <script is:inline set:html={langRedirectScript} />}
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={site + route[lang]} />
  <link rel="alternate" hreflang="en" href={site + route.en} />
  <link rel="alternate" hreflang="id" href={site + route.id} />
  <link rel="alternate" hreflang="ko" href={site + route.ko} />
  <link rel="alternate" hreflang="x-default" href={site + route.en} />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={site + route[lang]} />
  <meta property="og:image" content={site + '/images/brand/og-image.jpg'} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#00534B" />
  <meta property="og:locale" content={lang === 'id' ? 'id_ID' : lang === 'ko' ? 'ko_KR' : 'en_US'} />
  {(['en', 'id', 'ko'] as const).filter((l) => l !== lang).map((l) => (
    <meta property="og:locale:alternate" content={l === 'id' ? 'id_ID' : l === 'ko' ? 'ko_KR' : 'en_US'} />
  ))}
  <meta property="og:site_name" content="PUPA Center" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'EducationalOrganization',
    name: 'PUPA Center',
    alternateName: 'Yayasan PUPA Center',
    url: 'https://www.pupacenter.org',
    logo: 'https://www.pupacenter.org/images/brand/pupa-logo.png',
    image: 'https://www.pupacenter.org/images/brand/og-image.jpg',
    description: lang === 'id'
      ? 'Pusat pengembangan kecakapan hidup dan kesiapan kerja bagi anak muda neurodivergen di Tangerang, Indonesia.'
      : lang === 'ko'
      ? '인도네시아 탕에랑에 있는 신경다양성 청년을 위한 생활 기술 및 취업 준비 발달 센터입니다.'
      : 'A development center for life skills and work readiness for neurodivergent young adults in Tangerang, Indonesia.',
    slogan: 'Transform to shine',
    email: 'info@pupacenter.org',
    telephone: '+62818533698',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Ruko Prominence Blok 38E No. 42-43, Jl. Sutera Barat Boulevard, Alam Sutera',
      addressLocality: 'Tangerang',
      addressRegion: 'Banten',
      postalCode: '15143',
      addressCountry: 'ID',
    },
    geo: { '@type': 'GeoCoordinates', latitude: -6.2288, longitude: 106.6539 },
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'],
      opens: '09:00', closes: '15:00',
    },
    areaServed: { '@type': 'Place', name: 'Tangerang, Banten, Indonesia' },
    sameAs: [
      'https://www.instagram.com/pupa.center',
      'https://www.youtube.com/@PUPACenter',
    ],
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Varela+Round&family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <a class="skip-link" href="#main">{t('a11y.skip')}</a>
  <Header lang={lang} routeKey={routeKey} altRoute={altUrls} />
  <main id="main">
    <slot />
  </main>
  <Footer lang={lang} />
  <AccessibilityToolbar lang={lang} />
</body>
</html>
