---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
export async function getStaticPaths() {
  const stories = await getCollection('stories', (s) => s.data.lang === 'en');
  return stories.map((s) => ({ params: { slug: s.data.slug }, props: { story: s } }));
}
const { story } = Astro.props;
const __all = await getCollection('stories');
const __bases = { en: '/growth-journeys/', id: '/id/kisah/', ko: '/ko/growth-journeys/' };
const __alt = (l: 'en' | 'id' | 'ko') => {
  const k = story.data.translationKey;
  const m = k ? __all.find((e) => e.data.lang === l && e.data.translationKey === k) : undefined;
  return m ? __bases[l] + m.data.slug + '/' : __bases[l];
};
const altUrls = { en: __alt('en'), id: __alt('id'), ko: __alt('ko') };
const { Content } = await render(story);
---
<ArticleLayout lang="en" routeKey="stories" altUrls={altUrls} title={story.data.title} description={story.data.description ?? ''} image={story.data.image} backHref="/growth-journeys/" backLabel="All growth journeys">
  <Content />
</ArticleLayout>
